			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="numeroArt360" type="Art360Num" use="required">
			<xs:annotation>
				<xs:documentation>numero tra 1 e 5 riferito all'art. 360 primo comma</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
