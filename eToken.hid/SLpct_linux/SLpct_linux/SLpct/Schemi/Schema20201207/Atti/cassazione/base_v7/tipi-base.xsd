	<xs:complexType name="Motivo">
		<xs:sequence>
			<xs:element name="RiferimentoNorma" minOccurs="0" maxOccurs="unbounded">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="descrizione" type="xs:string">
							<xs:annotation>
								<xs:documentation>Riportare la norma (legge, codice, ecc) Per es. Ex art. 336 c.p.c.</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="comma" type="xs:string" minOccurs="0"/>
						<xs:element name="permaLink" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>URN delle norme, come definito da Normattiva detto anche permalink.</xs:documentation>
