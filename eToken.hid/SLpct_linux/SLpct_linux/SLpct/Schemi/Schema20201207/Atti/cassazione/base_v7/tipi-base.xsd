		</xs:sequence>
	</xs:complexType>
	<xs:simpleType name="TipoRicorso">
		<xs:annotation>
			<xs:documentation>Classificazione delle tipologie di ricorso</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="RegolamentoPreventivoDiGiurisdizione"/>
			<xs:enumeration value="RicorsoOrdinario"/>
			<xs:enumeration value="RegolamentoDiCompetenza"/>
			<xs:enumeration value="RicorsoPerRevocazione"/>
			<xs:enumeration value="Ricorso_ex_art_348_TER"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:annotation>
		<xs:documentation>Tipi primitivi utilizzati nella definizione degli schemi</xs:documentation>
	</xs:annotation>
	<xs:simpleType name="Valuta">
		<xs:annotation>
			<xs:documentation>Formato numerico accettato per l'indicazione di tutti gli importi</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:float">
			<xs:whiteSpace value="collapse"/>
			<xs:pattern value="\p{Nd}*(\.\p{Nd}{2,2})?"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="MateriaRicorso">
		<xs:annotation>
			<xs:documentation>Materia del ricorso</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="materia" type="MaterieRicorso"/>
			<xs:element name="paroleChiave" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Trattasi dell'Oggetto del giudizio. Vanno indicate al massimo 10 parole chiave tra quelle riportate nella nota di iscrizione a ruolo</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:simpleType name="Percentuale">
