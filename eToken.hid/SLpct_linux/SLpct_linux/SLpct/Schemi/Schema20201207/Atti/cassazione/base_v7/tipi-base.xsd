		<xs:restriction base="xs:string">
			<xs:whiteSpace value="collapse"/>
			<xs:pattern value="(\p{Nd}|\p{L}){14,16}"/>
			<xs:pattern value="[0-9]{11,11}"/>
			<xs:pattern value="(EX:[0-9]{13,13})"/>
