														<xs:sequence>
															<xs:element name="Presentate" type="xs:int">
																<xs:annotation>
																	<xs:documentation>Nr. domande di rivendica e restituzione presentate</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Accolte" type="xs:int">
