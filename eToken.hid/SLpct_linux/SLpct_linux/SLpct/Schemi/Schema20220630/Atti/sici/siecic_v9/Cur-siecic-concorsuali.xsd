									<xs:element name="LiquidatoriPrecedenti" minOccurs="0" maxOccurs="unbounded">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Nome"/>
												<xs:element name="Cognome"/>
												<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
												<xs:element name="IndicatoDalDebitore" type="xs:boolean" minOccurs="0"/>
												<xs:element name="NominatoDalTribunale" type="xs:boolean" minOccurs="0"/>
