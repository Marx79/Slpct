															<xs:element name="NumeroBeni" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero dei beni che fanno parte del lotto; il numero dei beni non va confuso con il numero delle particelle; un bene è tale, indipendentemente dal numero di particelle catastali che lo descrivono, quando è autonomamente fruibile; quindi, ad esempio, un box, un appartamento, una villetta, un capannone, ecc.</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Descrizione" type="xs:string"/>
