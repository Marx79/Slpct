																	<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, se valorizzato a zero specificare motivazione nel campo Note</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ImposteETasseTrasferimento" type="bt:Valuta" minOccurs="0"/>
															<xs:element name="SpeseDiLiquidazione">
																<xs:annotation>
																	<xs:documentation>Dato segretato: spese (Di cui per compensi a professionisti, Di cui per cancellazione formalita' pregiudizievoli, Di cui per altre spese)</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="CompensiProfessionisti" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Spese sostenute per compensi Ctu e Ausiliari, al netto di iva</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="CancellazionePregiudizievoli" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>spese sostenute per la cancellazione delle trascrizioni e iscrizioni pregiudizievoli, a qualsiasi titolo, anche per l’eventuale compenso al soggetto a cui detta attivita' sia stata delegata</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="AltreSpese" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>altre spese sostenute in relazione all’immobile, ad esempio: causa revocatoria, sfratto, esecuzione per rilascio, lavori di manutenzione, pratiche amministrative, ecc.</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="DataAggiudicazione" type="xs:date" minOccurs="0"/>
															<xs:element name="StatoDiOccupazione">
																<xs:simpleType>
																	<xs:restriction base="xs:string">
