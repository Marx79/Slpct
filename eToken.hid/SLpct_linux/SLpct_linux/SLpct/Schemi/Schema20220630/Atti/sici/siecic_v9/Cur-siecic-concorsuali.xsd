																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="EsecutivitaSP">
													<xs:annotation>
														<xs:documentation>esecutivita' dello stato passivo</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:choice>
															<xs:element name="DataEsecutivita" type="xs:date">
