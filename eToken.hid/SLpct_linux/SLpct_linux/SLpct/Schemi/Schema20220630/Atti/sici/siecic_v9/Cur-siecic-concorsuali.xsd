															<xs:enumeration value="notaio"/>
															<xs:enumeration value="ingegnere"/>
															<xs:enumeration value="architetto"/>
															<xs:enumeration value="geometra"/>
															<xs:enumeration value="societa specializzata"/>
															<xs:enumeration value="IVG"/>
															<xs:enumeration value="commissionario"/>
															<xs:enumeration value="altro"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Stato">
													<xs:annotation>
														<xs:documentation>Specificare il tipo di incarico, se lo stesso e di tipo altro descrivere nel campo note, il curatore deve riferire che lâ€™incarico e' â€œdefinitoâ€, quando il soggetto incaricato ha definito tutti gli incarichi affidatigli</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="in corso"/>
															<xs:enumeration value="definito"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Tipo">
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="stima"/>
															<xs:enumeration value="consulenza"/>
															<xs:enumeration value="legale giudiziale"/>
															<xs:enumeration value="legale stragiudiziale"/>
															<xs:enumeration value="recupero crediti ex art. 106 comma 3 LF"/>
															<xs:enumeration value="delega"/>
															<xs:enumeration value="custodia"/>
															<xs:enumeration value="coadiutore ex art. 32 comma 2 LF"/>
															<xs:enumeration value="altro"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="DataIncarico" type="xs:date">
													<xs:annotation>
														<xs:documentation>data in cui il curatore ha conferito lâ€™incarico al soggetto</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="Affari" type="xs:int">
													<xs:annotation>
														<xs:documentation>Nr. affari (o posizioni): vanno indicati il numero di â€œpraticheâ€ affidate dal curatore al soggetto incaricato; ad esempio, per i legali si trattera' di numero di crediti da recuperare, ma va rammentato che questa scheda non riguarda le cause; per il commercialista, il numero di incarichi (ad esempio: redazione della dichiarazione iva annuale, mod 770 per ciascun dipendente o professionista, ecc.); per lâ€™ingegnere, lâ€™architetto o il geometra, il numero di pratiche affidategli (progetto, domanda di condono, direzione dei lavori, collaudo, ecc.)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ValoreAffari" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valore complessivo nominale degli affari (o posizioni)  dello stesso tipo</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="AffariDefiniti" type="xs:int">
													<xs:annotation>
														<xs:documentation>: in questo campo il curatore deve indicare il numero di affari o posizioni affidati al soggetto incaricato e da questi definite; il numero di affari definiti puÃ² ovviamente essere inferiore o pari a quello che compare nel diverso check box denominato </xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ValoreAffariDefiniti" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valore complessivo nominale degli affari (o posizioni) definiti: va inserito il valore complessivo di tutti gli incarichi conferiti al medesimo professionista, da non confondersi con il compenso del soggetto incaricato (anche perchÃ© normalmente, quando lâ€™incarico e' in corso, il compenso non e' ancora noto)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="SommaIncassata" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valorizzare per il tipo incarico: legale giudiziale, legale stragiudiziale, recupero crediti ex art. 106 comma 3 LF; per gli altri tipi di incarico valorizzare a zero. Questo campo puÃ² non essere pertinente (ad esempio, in caso di incarico affidato a notaio o a ingegnere, architetto o geometra), perchÃ© normalmente a costoro non viene rimesso lâ€™incarico di recuperare denaro; in tal caso, il curatore deve inserire â€œ0,00â€ e nel campo note spiegare perchÃ© si tratta di voce non pertinente</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="TotaleCompensi" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il totale compensi liquidati, anche a titolo di acconto, va riferito all'incarico, anche se ricomprende piÃ¹ affari (o posizioni)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="TotaleSpese" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>totale altre spese sostenute per tutti gli incarichi dello stesso tipo</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="IncaricatoVendita" type="xs:boolean"/>
												<xs:element name="Note" type="xs:string" minOccurs="0">
													<xs:annotation>
														<xs:documentation>note da utilizzare specialmente per dettagliare il tipo di incarico qualora questo sia stato specificato come tipo altro</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="Cause">
							<xs:annotation>
								<xs:documentation>Dato segretato: tutti i dati relativi alle cause sono segretati</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Cognizione" minOccurs="0" maxOccurs="unbounded">
										<xs:annotation>
											<xs:documentation>Nel campo non dovranno essere specificate le cause riferite a decreti ingiuntivi</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Tipo">
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="giudice ordinario"/>
															<xs:enumeration value="giudice tributario"/>
															<xs:enumeration value="giudice amministrativo"/>
															<xs:enumeration value="giudice arbitrale"/>
															<xs:enumeration value="altre autorita giudiziarie"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="NumeroRgPrimoGrado" type="RiferimentoCausa"/>
												<xs:element name="PosizioneProcessualeFallimento">
													<xs:annotation>
														<xs:documentation>Va indicata la posizione processuale del fallimento (attore, convenuto, chiamata in causa, intervenuto; se si tratta di opposizione a decreto ingiuntivo, va inserita la posizione processuale formale del fallimento e quindi attore o convenuto a seconda che abbia promosso lâ€™opposizione a decreto ingiuntivo o lâ€™abbia subita, ma nel campo Note va spiegato che si tratta, appunto, di opposizione a decreto ingiuntivo)</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="attore"/>
															<xs:enumeration value="convenuto"/>
															<xs:enumeration value="chiamato in causa"/>
															<xs:enumeration value="intervenuto"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Stato">
													<xs:annotation>
														<xs:documentation>il curatore deve scegliere la voce â€œdefinito con sentenzaâ€ anche se la sentenza non e' ancora passata in giudicato; la voce â€œdefinito con sentenzaâ€ va scelta anche se la causa e' stata definita (non con sentenza, bensÃ¬) con lodo arbitrale; inoltre, questa voce va scelta anche se il provvedimento del giudice non e' una sentenza ma unâ€™ordinanza o un decreto</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="pendente"/>
															<xs:enumeration value="definito con sentenza"/>
															<xs:enumeration value="definito in altro modo"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Oggetto">
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="recupero crediti verso clienti"/>
															<xs:enumeration value="revocatoria"/>
															<xs:enumeration value="opposizione stato passivo"/>
															<xs:enumeration value="azioni risarcitorie"/>
															<xs:enumeration value="altro"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="ValoreDomanda" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>va inserito il valore della causa e cioe' quanto e' stato chiesto dal o contro il fallimento; il sistema non consente di inserire dati alfabetici, ma solo numerici; pertanto, se il valore e' indeterminabile, il curatore deve inserire â€œ0,00â€ e, nel campo note, spiegare che si tratta di valore indeterminabile, indicandone anche le ragioni</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ImportoDispositivo">
													<xs:annotation>
														<xs:documentation>Importo contenuto nel dispositivo con indicazione  se la statuizione  e' a favore del fallimento (aFavore=true), oppure, se la sentenza e' contro il fallimento (aFavore=false). Indicare  lâ€™importo del dispositivo contenuto nella sentenza o nel lodo arbitrale. Se il dispositivo non contiene alcun importo, occorre inserire â€œ0,00â€ e spiegare le ragioni nel campo note.
							</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:simpleContent>
															<xs:extension base="bt:Valuta">
																<xs:attribute name="aFavore" type="xs:boolean" use="required"/>
															</xs:extension>
														</xs:simpleContent>
													</xs:complexType>
												</xs:element>
												<xs:element name="Spese" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>vanno indicati tutti gli importi che il curatore ha pagato, non solo al professionista incaricato della causa, ma anche ad altri soggetti (ad esempio: per le verifiche sul patrimonio del debitore, per il consulente tecnico dâ€™ufficio o di parte, ecc.), al netto di iva</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ImportoIncassatoAzioneEsecutiva" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>indicare  lâ€™importo  che il curatore e' riuscito ad incassare dopo avere esperito lâ€™azione esecutiva (pignoramento immobiliare, mobiliare, presso terzi o giudizio di ottemperanza davanti al giudice amministrativo). Se il curatore non ha incassato alcun importo mediante esperimento dellâ€™azione esecutiva, occorre inserire â€œ0,00â€</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ImportoIncassatoAltraAzione" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>Importo incassato in altro modo: indicare  lâ€™importo  che il curatore e' riuscito ad incassare, senza avere esperito lâ€™azione esecutiva e indipendentemente dal fatto che sia stata pronunciata sentenza o lodo arbitrale; ad esempio, quando lâ€™importo e' stato incassato a seguito di transazione, o di verbale di conciliazione, ecc. Se il curatore non ha incassato alcun importo, occorre inserire â€œ0,00â€</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="Legale">
													<xs:annotation>
														<xs:documentation>Cognome e nome del legale incaricato</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Nome" type="xs:string"/>
															<xs:element name="Cognome" type="xs:string"/>
															<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="Note" type="xs:string" minOccurs="0"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="Esecutive" minOccurs="0" maxOccurs="unbounded">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="TipoEsecuzione">
													<xs:complexType>
														<xs:choice>
															<xs:element name="Gruppo1">
																<xs:annotation>
																	<xs:documentation>immobiliare; mobiliare; espropriazione presso terzi; giudizio di ottemperanza</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="Tipo">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="immobiliare"/>
																					<xs:enumeration value="mobiliare"/>
																					<xs:enumeration value="espropriazione presso terzi"/>
																					<xs:enumeration value="giudizio di ottemperanza"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																		<xs:element name="Stato">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="in corso"/>
																					<xs:enumeration value="definito"/>
																					<xs:enumeration value="sospeso"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																		<xs:element name="ImportoCredito" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>va inserito lâ€™importo del credito per cui il curatore agisce esecutivamente e, quindi, quando câ€™e', lâ€™importo indicato nel precetto; altrimenti, quello risultante dal titolo esecutivo (sentenza, titolo di credito, ecc.)</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="ValoreBeni" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>valorizzato solo per procedimento mobiliari e immobiliari: va indicato il valore dei beni risultante dalla stima o dal pignoramento mobiliare; il campo e' obbligatorio anche quando il curatore ha indicato, nel tipo di processo, il giudizio di ottemperanza o lâ€™espropriazione presso terzi, anche se in questi casi non vi sono beni pignorati e, quindi, non e' possibile indicarne il valore; pertanto, in questi casi il curatore deve indicare il valore â€œ0,00â€ e, nel campo â€œNoteâ€, spiegare che si tratta, appunto, di giudizio che non prevede il pignoramento di beni </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="SommaIncassata" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Somma complessivamente incassata: se non ha incassato ancora nulla, il curatore deve indicare â€œ0,00â€ e nel campo Note spiegarne le ragioni</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="Gruppo2">
																<xs:annotation>
																	<xs:documentation>esecuzione obblighi di fare; consegna o rilascio</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="Tipo">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="esecuzione obblighi di fare"/>
																					<xs:enumeration value="consegna o rilascio"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																		<xs:element name="Stato">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="definito positivamente"/>
																					<xs:enumeration value="definito negativamente"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
														</xs:choice>
													</xs:complexType>
												</xs:element>
												<xs:element name="NumeroRgPrimoGrado" type="RiferimentoCausa"/>
												<xs:element name="Spese" type="bt:Valuta"/>
												<xs:element name="Legale" minOccurs="0">
													<xs:annotation>
														<xs:documentation>Cognome e nome del legale incaricato</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Nome" type="xs:string"/>
															<xs:element name="Cognome" type="xs:string"/>
															<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="Note" type="xs:string" minOccurs="0"/>
												<xs:choice>
													<xs:element name="ProcessoEsecutivo107" type="xs:boolean">
														<xs:annotation>
															<xs:documentation>processo esecutivo ex art. 107, sesto comma, LF, o ex art. 41 TUB</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="ProcessoEsecutivo" type="xs:boolean">
														<xs:annotation>
															<xs:documentation>processo esecutivo finalizzato al realizzo di crediti</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:choice>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="ResponsabilitaCivile">
							<xs:annotation>
								<xs:documentation>Dato segretato: tutti i dati relativi alle responsabilita' civili sono segretati</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:choice>
									<xs:element name="Nessuna" type="xs:string">
										<xs:annotation>
											<xs:documentation>Motivazione nel caso non siano emerse ipotesi di responsabilita'</xs:documentation>
										</xs:annotation>
									</xs:element>
									<xs:choice>
										<xs:annotation>
											<xs:documentation>sono emerse ipotesi di responsabilita' civile</xs:documentation>
										</xs:annotation>
										<xs:element name="Motivazione" type="xs:string">
											<xs:annotation>
												<xs:documentation>motivazione se non sono state intraprese cause</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="Civile" maxOccurs="unbounded">
											<xs:complexType>
												<xs:sequence>
													<xs:element name="Ruolo" type="RiferimentoCausa">
														<xs:annotation>
															<xs:documentation>riferimento al ruolo della causa civile</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="Stato">
														<xs:simpleType>
															<xs:restriction base="xs:string">
																<xs:enumeration value="pendente"/>
																<xs:enumeration value="definita con sentenza"/>
																<xs:enumeration value="definita in altro modo"/>
															</xs:restriction>
														</xs:simpleType>
													</xs:element>
													<xs:element name="ValoreCausa" type="bt:Valuta"/>
													<xs:element name="Legale">
														<xs:annotation>
															<xs:documentation>Cognome e nome del legale incaricato</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="Nome" type="xs:string"/>
																<xs:element name="Cognome" type="xs:string"/>
																<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
															</xs:sequence>
														</xs:complexType>
													</xs:element>
													<xs:element name="TipoCivile" maxOccurs="7">
														<xs:annotation>
															<xs:documentation>Tipologia di azione civile, possono essere specificate piÃ¹ tra le tipologie previste</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:simpleContent>
																<xs:extension base="xs:string">
																	<xs:attribute name="tipo" use="required">
																		<xs:simpleType>
																			<xs:restriction base="xs:string">
																				<xs:enumeration value="prosecuzione dell'attivita nonostante la perdita del capitale"/>
																				<xs:enumeration value="conflitto di interesse"/>
																				<xs:enumeration value="rimborso ai soci di crediti postergati"/>
																				<xs:enumeration value="sanzioni per omesso pagamento di crediti tributari e previdenziali"/>
																				<xs:enumeration value="distrazione di azienda o di beni per finalita extrasociali"/>
																				<xs:enumeration value="ricorso abusivo al credito"/>
																				<xs:enumeration value="altre ipotesi di responsabilita civile"/>
																			</xs:restriction>
																		</xs:simpleType>
																	</xs:attribute>
																</xs:extension>
															</xs:simpleContent>
														</xs:complexType>
													</xs:element>
													<xs:element name="Convenuti" type="xs:int">
														<xs:annotation>
															<xs:documentation>Nr. convenuti</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="ConvenutiCondannati" type="xs:int" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Nr. convenuti condannati</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="ProvvedimentiCautelari" type="xs:boolean"/>
													<xs:element name="ImportoInSentenza" type="bt:Valuta">
														<xs:annotation>
															<xs:documentation>Importo riconosciuto in sentenza</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="ImportoIncassato" type="bt:Valuta" minOccurs="0">
														<xs:annotation>
															<xs:documentation>lâ€™importo incassato a seguito di esecuzione esecutiva</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="ImportoIncassatoAltro" type="bt:Valuta" minOccurs="0">
														<xs:annotation>
															<xs:documentation>importo incassato in altro modo</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="Spese" type="bt:Valuta">
														<xs:annotation>
															<xs:documentation>Spese sostenute</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="Note" type="xs:string"/>
												</xs:sequence>
											</xs:complexType>
											<xs:unique name="TipoCivileUnique">
												<xs:selector xpath="TipoCivile"/>
