											<xs:sequence>
												<xs:element name="Nome" type="xs:string"/>
												<xs:element name="Cognome" type="xs:string"/>
												<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="RiferimentiBancari">
										<xs:complexType>
											<xs:choice>
												<xs:element name="ContoCorrente">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="IBAN" type="xs:string">
																<xs:annotation>
																	<xs:documentation>codice IBAN per il conto corrente</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Saldo" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>saldo del conto corrente</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Banca" type="xs:string">
																<xs:annotation>
																	<xs:documentation>banca presso la quale è stato aperto il conto</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Agenzia" type="xs:string">
																<xs:annotation>
																	<xs:documentation>agenzia presso la quale è stato aperto il conto</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="DataSaldo" type="xs:date">
																<xs:annotation>
																	<xs:documentation>data alla quale si riferisce il saldo del conto corrente</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="Libretto">
													<xs:annotation>
														<xs:documentation>Dati del libretto solo per le procedure aperte prima del 16.07.2006</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Banca" type="xs:string">
																<xs:annotation>
																	<xs:documentation>banca presso la quale è stato aperto il libretto</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Agenzia" type="xs:string">
																<xs:annotation>
																	<xs:documentation>agenzia presso la quale è stato aperto il libretto</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Numero" type="xs:string">
																<xs:annotation>
																	<xs:documentation>numero del libretto</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Saldo" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>saldo del libretto</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="DataSaldo" type="xs:date">
																<xs:annotation>
																	<xs:documentation>data alla quale si riferisce il saldo del libretto</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="StrumentoFinanziario">
													<xs:annotation>
														<xs:documentation>Descrizione di altro strumento finanziario</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:simpleContent>
															<xs:extension base="bt:Valuta">
																<xs:attribute name="descrizione" type="xs:string"/>
															</xs:extension>
														</xs:simpleContent>
													</xs:complexType>
												</xs:element>
											</xs:choice>
										</xs:complexType>
									</xs:element>
									<xs:element name="Somme">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="AttivoRealizzato" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>Importi incassati a seguito di vendite di beni o di recupero di crediti o di cause definite, al netto dell’Iva</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="AttivoDaRealizzare" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valore complessivo di immobili, mobili e crediti che non sono stati ancora venduti o incassati o di somme ricevute a seguito di cause non ancora definite; il valore dovra' essere  quello complessivo (cioè la somma dei valori dei beni suddetti) e dovra' tener conto degli eventuali ribassi effettuati nei precedenti tentativi di vendita e, per quanto riguarda i crediti, delle eventuali contestazioni dei debitori e della eventuale ridotta o nulla capacita' patrimoniale dei debitori.</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="DebitiConcordatari" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>Tquesto dato deve contenere sia i debiti indicati nella proposta, che tutte le prededuzioni maturate sino alla data del rapporto riepilogativo</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="DataChiusura" type="xs:dateTime" minOccurs="0">
