																			<xs:annotation>
																				<xs:documentation>Dato segretato: compensi a professionisti</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="CancellazionePregiudizievoli" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Dato segretato: per cancellazione formalita' pregiudizievoli</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="AltreSpese" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Dato segretato: per altre spese</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="ValoreNominale" type="bt:Valuta"/>
															<xs:element name="ValoreStima" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>Tale valore potrebbe riferirsi ad una stima del curatore e non necessariamente ad una perizia</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ValoreStimaProposta" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>valore di stima indicato nella proposta</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ImportoRealizzato" type="bt:Valuta"/>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="Passivo">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Crediti">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="DichiaratiDaiCreditori">
													<xs:annotation>
														<xs:documentation>Nr. crediti dichiarati dai creditori</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="Riconosciuti">
													<xs:annotation>
														<xs:documentation>-	Nr. crediti riconosciuti dal commissario o dal liquidatore</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="NonRiconosciuti">
													<xs:annotation>
														<xs:documentation>-	Nr. crediti non riconosciuti dal commissario o dal liquidatore</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="InCorsoAccertamento">
													<xs:annotation>
														<xs:documentation>-	Nr. crediti per i quali è in corso un’azione di accertamento da parte del creditore nei confronti del liquidatore</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="ClassificazioneGiuridica">
										<xs:annotation>
											<xs:documentation>Per ciascuna delle 4 categorie giuridiche di crediti (prededucibili, ipotecari, privilegiati, chirografari) il curatore deve inserire:
						-	l’ammontare complessivo dei crediti ammesso 
						-	e, inoltre, l’ammontare complessivo dei crediti ammesso con riserva.
											</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Ammessi">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="CreditiPrededucibili" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Ipotecari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Privilegiati" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Chirografari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="AmmessiConRiserva">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="CreditiPrededucibili" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Ipotecari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Privilegiati" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Chirografari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="ClassificazioneEconomica" minOccurs="11" maxOccurs="11">
										<xs:annotation>
											<xs:documentation>Classificazione economica e comparazione dei crediti</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="CategoriaEconomica" type="CategoriaEconomica"/>
												<xs:element name="DebitiPenultimoEsercizio" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il curatore deve inserire, per ciascuna categoria economica, l’ammontare complessivo dei debiti del fallito appartenenti a quella specifica categoria economica e che risultano dal  bilancio depositato (o comunque rinvenuto presso la sede dell’impresa, anche se non depositato o approvato) relativo a due esercizi precedenti a quello in corso alla dichiarazione di fallimento</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="DebitiUltimoEsercizio" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il curatore deve inserire, per ciascuna categoria economica, l’ammontare complessivo dei debiti del fallito appartenenti a quella specifica categoria economica e che risultano dal  bilancio depositato (o comunque rinvenuto presso la sede dell’impresa, anche se non depositato o approvato) relativo all’esercizio precedente a quello in corso alla dichiarazione di fallimento</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="CreditiAmmessiAlPassivo" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>va inserito, per ciascuna categoria economica, l’ammontare complessivo dei debiti del fallito ammessi al passivo ed appartenenti a quella specifica categoria economica</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="DebitiAlFallimento" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il curatore deve inserire, per ciascuna categoria economica, l’ammontare complessivo dei debiti del fallito appartenenti a quella specifica categoria economica e che risultano dalla contabilita' (libro giornale, ecc.) rinvenuta presso la sede dell’impresa</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="CreditiAmmessiConRiserva" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>va inserito, per ciascuna categoria economica, l’ammontare complessivo dei debiti del fallito ammessi al passivo con riserva ed appartenenti a quella specifica categoria economica</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
							<xs:unique name="ClassificazioneEconomicaUniqueConcordato">
								<xs:selector xpath="ClassificazioneEconomica"/>
								<xs:field xpath="CategoriaEconomica"/>
							</xs:unique>
						</xs:element>
						<xs:element name="Incarichi">
							<xs:annotation>
								<xs:documentation>Dato segretato: tutti i dati relativi agli incarichi sono segretati</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Incarico" minOccurs="0" maxOccurs="unbounded">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Cognome" type="xs:string"/>
												<xs:element name="Nome" type="xs:string"/>
												<xs:element name="CodiceFiscale" type="xs:string"/>
												<xs:element name="CategoriaProfessionale">
													<xs:annotation>
														<xs:documentation>Specificare il tipo di incarico, se lo stesso e di tipo altro descrivere nel campo note</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="avvocato"/>
															<xs:enumeration value="commercialista"/>
															<xs:enumeration value="notaio"/>
															<xs:enumeration value="ingegnere"/>
															<xs:enumeration value="architetto"/>
															<xs:enumeration value="geometra"/>
															<xs:enumeration value="societa specializzata"/>
															<xs:enumeration value="IVG"/>
															<xs:enumeration value="commissionario"/>
															<xs:enumeration value="altro"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Stato">
													<xs:annotation>
														<xs:documentation>Specificare il tipo di incarico, se lo stesso e di tipo altro descrivere nel campo note, il curatore deve riferire che l’incarico è “definito”, quando il soggetto incaricato ha definito tutti gli incarichi affidatigli</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="in corso"/>
															<xs:enumeration value="definito"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Tipo">
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="stima"/>
															<xs:enumeration value="consulenza"/>
															<xs:enumeration value="legale giudiziale"/>
															<xs:enumeration value="legale stragiudiziale"/>
															<xs:enumeration value="recupero crediti ex art. 106 comma 3 LF"/>
															<xs:enumeration value="delega"/>
															<xs:enumeration value="custodia"/>
															<xs:enumeration value="coadiutore ex art. 32 comma 2 LF"/>
															<xs:enumeration value="altro"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="DataIncarico" type="xs:date">
													<xs:annotation>
														<xs:documentation>data in cui il curatore ha conferito l’incarico al soggetto</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="Affari" type="xs:int">
													<xs:annotation>
														<xs:documentation>Nr. affari (o posizioni): vanno indicati il numero di “pratiche” affidate dal curatore al soggetto incaricato; ad esempio, per i legali si trattera' di numero di crediti da recuperare, ma va rammentato che questa scheda non riguarda le cause; per il commercialista, il numero di incarichi (ad esempio: redazione della dichiarazione iva annuale, mod 770 per ciascun dipendente o professionista, ecc.); per l’ingegnere, l’architetto o il geometra, il numero di pratiche affidategli (progetto, domanda di condono, direzione dei lavori, collaudo, ecc.)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ValoreAffari" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valore complessivo nominale degli affari (o posizioni)  dello stesso tipo</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="AffariDefiniti" type="xs:int">
													<xs:annotation>
														<xs:documentation>: in questo campo il curatore deve indicare il numero di affari o posizioni affidati al soggetto incaricato e da questi definite; il numero di affari definiti può ovviamente essere inferiore o pari a quello che compare nel diverso check box denominato </xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ValoreAffariDefiniti" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valore complessivo nominale degli affari (o posizioni) definiti: va inserito il valore complessivo di tutti gli incarichi conferiti al medesimo professionista, da non confondersi con il compenso del soggetto incaricato (anche perché normalmente, quando l’incarico è in corso, il compenso non è ancora noto)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="SommaIncassata" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>valorizzare per il tipo incarico: legale giudiziale, legale stragiudiziale, recupero crediti ex art. 106 comma 3 LF; per gli altri tipi di incarico valorizzare a zero. Questo campo può non essere pertinente (ad esempio, in caso di incarico affidato a notaio o a ingegnere, architetto o geometra), perché normalmente a costoro non viene rimesso l’incarico di recuperare denaro; in tal caso, il curatore deve inserire “0,00” e nel campo note spiegare perché si tratta di voce non pertinente</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="TotaleCompensi" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il totale compensi liquidati, anche a titolo di acconto, va riferito all'incarico, anche se ricomprende più affari (o posizioni)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="TotaleSpese" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>totale altre spese sostenute per tutti gli incarichi dello stesso tipo</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="IncaricatoVendita" type="xs:boolean"/>
												<xs:element name="Note" type="xs:string" minOccurs="0">
													<xs:annotation>
														<xs:documentation>note da utilizzare specialmente per dettagliare il tipo di incarico qualora questo sia stato specificato come tipo altro</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="Cause">
							<xs:annotation>
								<xs:documentation>Dato segretato: tutti i dati relativi alle cause sono segretati</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Cognizione" minOccurs="0" maxOccurs="unbounded">
										<xs:annotation>
											<xs:documentation>Nel campo non dovranno essere specificate le cause riferite a decreti ingiuntivi</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Tipo">
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="giudice ordinario"/>
															<xs:enumeration value="giudice tributario"/>
															<xs:enumeration value="giudice amministrativo"/>
															<xs:enumeration value="giudice arbitrale"/>
															<xs:enumeration value="altre autorita giudiziarie"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="NumeroRgPrimoGrado" type="RiferimentoCausa"/>
												<xs:element name="PosizioneProcessualeFallimento">
													<xs:annotation>
														<xs:documentation>Va indicata la posizione processuale del fallimento (attore, convenuto, chiamata in causa, intervenuto; se si tratta di opposizione a decreto ingiuntivo, va inserita la posizione processuale formale del fallimento e quindi attore o convenuto a seconda che abbia promosso l’opposizione a decreto ingiuntivo o l’abbia subita, ma nel campo Note va spiegato che si tratta, appunto, di opposizione a decreto ingiuntivo)</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="attore"/>
															<xs:enumeration value="convenuto"/>
															<xs:enumeration value="chiamato in causa"/>
															<xs:enumeration value="intervenuto"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Stato">
													<xs:annotation>
														<xs:documentation>il curatore deve scegliere la voce “definito con sentenza” anche se la sentenza non è ancora passata in giudicato; la voce “definito con sentenza” va scelta anche se la causa è stata definita (non con sentenza, bensì) con lodo arbitrale; inoltre, questa voce va scelta anche se il provvedimento del giudice non è una sentenza ma un’ordinanza o un decreto</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="pendente"/>
															<xs:enumeration value="definito con sentenza"/>
															<xs:enumeration value="definito in altro modo"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="Oggetto">
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:enumeration value="recupero crediti verso clienti"/>
															<xs:enumeration value="revocatoria"/>
															<xs:enumeration value="opposizione stato passivo"/>
															<xs:enumeration value="azioni risarcitorie"/>
															<xs:enumeration value="altro"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="ValoreDomanda" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>va inserito il valore della causa e cioè quanto è stato chiesto dal o contro il fallimento; il sistema non consente di inserire dati alfabetici, ma solo numerici; pertanto, se il valore è indeterminabile, il curatore deve inserire “0,00” e, nel campo note, spiegare che si tratta di valore indeterminabile, indicandone anche le ragioni</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ImportoDispositivo">
													<xs:annotation>
														<xs:documentation>Importo contenuto nel dispositivo con indicazione  se la statuizione  è a favore del fallimento (aFavore=true), oppure, se la sentenza è contro il fallimento (aFavore=false). Indicare  l’importo del dispositivo contenuto nella sentenza o nel lodo arbitrale. Se il dispositivo non contiene alcun importo, occorre inserire “0,00” e spiegare le ragioni nel campo note.
														</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:simpleContent>
															<xs:extension base="bt:Valuta">
																<xs:attribute name="aFavore" type="xs:boolean" use="required"/>
															</xs:extension>
														</xs:simpleContent>
													</xs:complexType>
												</xs:element>
												<xs:element name="Spese" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>vanno indicati tutti gli importi che il curatore ha pagato, non solo al professionista incaricato della causa, ma anche ad altri soggetti (ad esempio: per le verifiche sul patrimonio del debitore, per il consulente tecnico d’ufficio o di parte, ecc.), al netto di iva</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ImportoIncassatoAzioneEsecutiva" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>indicare  l’importo  che il curatore è riuscito ad incassare dopo avere esperito l’azione esecutiva (pignoramento immobiliare, mobiliare, presso terzi o giudizio di ottemperanza davanti al giudice amministrativo). Se il curatore non ha incassato alcun importo mediante esperimento dell’azione esecutiva, occorre inserire “0,00”</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="ImportoIncassatoAltraAzione" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>Importo incassato in altro modo: indicare  l’importo  che il curatore è riuscito ad incassare, senza avere esperito l’azione esecutiva e indipendentemente dal fatto che sia stata pronunciata sentenza o lodo arbitrale; ad esempio, quando l’importo è stato incassato a seguito di transazione, o di verbale di conciliazione, ecc. Se il curatore non ha incassato alcun importo, occorre inserire “0,00”</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="Legale">
													<xs:annotation>
														<xs:documentation>Cognome e nome del legale incaricato</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Nome" type="xs:string"/>
															<xs:element name="Cognome" type="xs:string"/>
															<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="Note" type="xs:string" minOccurs="0"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="Esecutive" minOccurs="0" maxOccurs="unbounded">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="TipoEsecuzione">
													<xs:complexType>
														<xs:choice>
															<xs:element name="Gruppo1">
																<xs:annotation>
																	<xs:documentation>immobiliare; mobiliare; espropriazione presso terzi; giudizio di ottemperanza</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="Tipo">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="immobiliare"/>
																					<xs:enumeration value="mobiliare"/>
																					<xs:enumeration value="espropriazione presso terzi"/>
																					<xs:enumeration value="giudizio di ottemperanza"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																		<xs:element name="Stato">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="in corso"/>
																					<xs:enumeration value="definito"/>
																					<xs:enumeration value="sospeso"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																		<xs:element name="ImportoCredito" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>va inserito l’importo del credito per cui il curatore agisce esecutivamente e, quindi, quando c’è, l’importo indicato nel precetto; altrimenti, quello risultante dal titolo esecutivo (sentenza, titolo di credito, ecc.)</xs:documentation>
