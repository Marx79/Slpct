											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="ClassificazioneEconomica" minOccurs="11" maxOccurs="11">
										<xs:annotation>
											<xs:documentation>Classificazione economica e comparazione dei debiti</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="CategoriaEconomica" type="CategoriaEconomica"/>
												<xs:element name="DebitiPenultimoEsercizio" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il curatore deve inserire, per ciascuna categoria economica, lâ€™ammontare complessivo dei debiti del fallito appartenenti a quella specifica categoria economica e che risultano dal  bilancio depositato (o comunque rinvenuto presso la sede dellâ€™impresa, anche se non depositato o approvato) relativo a due esercizi precedenti a quello in corso alla dichiarazione di fallimento</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="DebitiUltimoEsercizio" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il curatore deve inserire, per ciascuna categoria economica, lâ€™ammontare complessivo dei debiti del fallito appartenenti a quella specifica categoria economica e che risultano dal  bilancio depositato (o comunque rinvenuto presso la sede dellâ€™impresa, anche se non depositato o approvato) relativo allâ€™esercizio precedente a quello in corso alla dichiarazione di fallimento</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="CreditiAmmessiAlPassivo" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>va inserito, per ciascuna categoria economica, lâ€™ammontare complessivo dei debiti del fallito ammessi al passivo ed appartenenti a quella specifica categoria economica</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="DebitiAlFallimento" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>il curatore deve inserire, per ciascuna categoria economica, lâ€™ammontare complessivo dei debiti del fallito appartenenti a quella specifica categoria economica e che risultano dalla contabilita' (libro giornale, ecc.) rinvenuta presso la sede dellâ€™impresa</xs:documentation>
													</xs:annotation>
												</xs:element>
