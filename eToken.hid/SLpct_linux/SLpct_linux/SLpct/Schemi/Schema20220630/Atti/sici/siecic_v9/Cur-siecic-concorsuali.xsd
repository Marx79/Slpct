														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="CreditiCeduti" minOccurs="0" maxOccurs="unbounded">
													<xs:annotation>
														<xs:documentation>Questa maschera riguarda i crediti che il curatore ha ceduto (pro solvendo o pro soluto, è indifferente) a soggetti terzi, ricevendo un pagamento dal cessionario (pagamento che verra' inserito nel check box denominato “importo realizzato”).</xs:documentation>
													</xs:annotation>
