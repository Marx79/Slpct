												<xs:element name="ImportoComplessivo" type="bt:Valuta"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="OrganiProcedura">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="GiudiceDelegato">
