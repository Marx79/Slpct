																			</xs:annotation>
																		</xs:element>
																		<xs:element name="SpeseOccupazione" type="bt:Valuta"/>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="Stato" type="StatoLotto"/>
															<xs:element name="TipoLiquidazione">
