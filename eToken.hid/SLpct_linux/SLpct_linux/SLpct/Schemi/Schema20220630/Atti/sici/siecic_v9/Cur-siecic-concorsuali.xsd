																		<xs:element name="Qualifica">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="curatore"/>
																					<xs:enumeration value="professionista"/>
																					<xs:enumeration value="societa di recupero"/>
																					<xs:enumeration value="altro"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="Intervallo1" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero di posizioni creditorie ciascuna inferiore a 50.000,00</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Intervallo2" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero di posizioni creditorie ciascuna compresa tra 50.000,00 e 100.000,00</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Intervallo3" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero di posizioni creditorie ciascuna superiore a 100.000,00</xs:documentation>
																</xs:annotation>
