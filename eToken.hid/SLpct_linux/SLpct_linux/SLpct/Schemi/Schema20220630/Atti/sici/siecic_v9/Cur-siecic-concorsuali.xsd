						<xs:element name="Cause">
							<xs:annotation>
								<xs:documentation>Dato segretato: tutti i dati relativi alle cause sono segretati</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Cognizione" minOccurs="0" maxOccurs="unbounded">
										<xs:annotation>
											<xs:documentation>Nel campo non dovranno essere specificate le cause riferite a decreti ingiuntivi</xs:documentation>
