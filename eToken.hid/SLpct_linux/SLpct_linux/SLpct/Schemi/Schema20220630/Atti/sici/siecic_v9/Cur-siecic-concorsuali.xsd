																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Pignoratizi" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="AmmessiConRiserva">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="CreditiPrededucibili" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Ipotecari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Privilegiati" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Chirografari" type="bt:Valuta">
