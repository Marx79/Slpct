									<xs:element name="Crediti">
										<xs:complexType>
											<xs:sequence minOccurs="0">
												<xs:element name="CreditiRiscossi" minOccurs="5" maxOccurs="5">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Tipologia" type="TipologiaCreditiConcordato">
																<xs:annotation>
																	<xs:documentation>“CREDITI DA AZIONI REVOCATORIE”: è necessario indicare che si tratta solo di crediti pecuniari (non anche ad esempio un credito per la restituzione di un bene  ceduto con atto revocabile), anche se non c’è la sentenza, e che dopo la sentenza, va inserito l’importo accertato ( e non quello preteso dal curatore).</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Intervallo1" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero di posizioni creditorie ciascuna inferiore a 50.000,00: va indicato il numero di crediti, ciascuno di essi di valore nominale inferiore a € 50.000,00, di cui il fallito è titolare nei confronti di soggetti terzi (clienti, ecc.)</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Intervallo2" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero di posizioni creditorie ciascuna compresa tra 50.000,00 e 100.000,00: va indicato il numero di crediti, ciascuno di essi di valore nominale ricompreso tra € 50.000,00 e € 100.000,00, di cui il fallito è titolare nei confronti di soggetti terzi (clienti, ecc.)</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Intervallo3" type="xs:int">
																<xs:annotation>
																	<xs:documentation>numero di posizioni creditorie ciascuna superiore a 100.000,00: va indicato il numero di crediti, ciascuno di essi di valore nominale superiori a € 100.000,00, di cui il fallito è titolare nei confronti di soggetti terzi (clienti, ecc.)</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Complessivo" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>si deve inserire la somma di tutti i crediti del fallito, secondo il loro valore nominale</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Stima" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>si deve inserire la somma di tutti i crediti del fallito, ma questa volta assumendo non il valore nominale dei crediti, ma gli importi che il curatore ritiene che sia effettivamente possibile realizzare, tenendo conto (sulla base di un giudizio prognostico) delle contestazioni del soggetto che è debitore verso il fallito, degli accertamenti che il curatore deve aver svolto sulla solvibilita' del soggetto debitore, ecc.</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ImportoRealizzato" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>il curatore deve indicare le somme che ha incassato dai soggetti debitori verso il fallito</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ImportoIva" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo IVA, se non presente indicare 0</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Spese">
																<xs:annotation>
																	<xs:documentation>Dato segretato: spese (Di cui per compensi a professionisti, Di cui per cancellazione formalita' pregiudizievoli, Di cui per altre spese)</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="CompensiProfessionisti" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>vanno inserite le spese per i compensi a professionisti (avvocati, consulenti, visuristi, societa' specializzate per la riscossione dei crediti, ecc.) e le spese vive rimborsate a costoro, nel loro valore complessivo, cioè indipendentemente dal valore nominale dei crediti; vanno invece distinte le spese (per compensi e rimborsi di spese vive) a seconda della tipologia di crediti (e cioè: verso clienti, verso societa' controllate, verso l’erario, da azioni revocatorie, altri crediti) </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="CancellazionePregiudizievoli" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Dato segretato: per cancellazione formalita' pregiudizievoli</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="AltreSpese" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Dato segretato: per altre spese</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="CreditiInFaseDiRiscossione" minOccurs="0" maxOccurs="unbounded">
													<xs:annotation>
														<xs:documentation>
							    il curatore deve inserire soltanto i crediti che non sono stati ancora riscossi, vanno inseriti in questa maschera (e non in quella precedente, relativa ai “crediti riscossi”) anche le posizioni creditorie che sono state incassate in parte, ma che il curatore non considera ancora definite, perché sono in corso ulteriori tentativi di incassare maggiori importi.</xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:sequence>
															<xs:element name="Tipologia" type="TipologiaCreditiConcordato"/>
															<xs:element name="SoggettoIncarico">
																<xs:complexType>
																	<xs:sequence>
