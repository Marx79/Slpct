																			<xs:annotation>
																				<xs:documentation>Dato segretato: compensi a professionisti</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="CancellazionePregiudizievoli" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Dato segretato: per cancellazione formalita' pregiudizievoli</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="AltreSpese" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Dato segretato: per altre spese</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="CreditiAbbandonati" minOccurs="5" maxOccurs="5">
													<xs:annotation>
														<xs:documentation>Questa maschera riguarda crediti che il curatore, al momento della redazione del rapporto riepilogativo, è stato autorizzato ad abbandonare (per le ragioni più varie, ad esempio la antieconomicita' dei tentativi di recupero.</xs:documentation>
													</xs:annotation>
													<xs:complexType>
