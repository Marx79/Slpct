												<xs:element name="Lotto">
													<xs:complexType>
														<xs:complexContent>
															<xs:extension base="LottoMobiliareConcordato">
																<xs:sequence>
																	<xs:element name="NumeroLotto" type="xs:string"/>
																	<xs:element name="Composizione">
																		<xs:simpleType>
																			<xs:restriction base="xs:string">
																				<xs:enumeration value="attrezzature"/>
