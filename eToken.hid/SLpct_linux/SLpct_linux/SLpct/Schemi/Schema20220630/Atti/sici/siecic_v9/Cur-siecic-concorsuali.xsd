																	<xs:documentation>valore complessivo di stima delle posizioni debitorie</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ImportoIva" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo IVA, se non presente indicare 0</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Spese">
																<xs:annotation>
																	<xs:documentation>Dato segretato: spese (Di cui per compensi a professionisti, Di cui per cancellazione formalita' pregiudizievoli, Di cui per altre spese)</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
