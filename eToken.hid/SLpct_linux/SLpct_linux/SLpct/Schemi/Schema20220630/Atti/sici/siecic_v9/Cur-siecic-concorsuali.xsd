														<xs:restriction base="xs:date">
															<xs:minInclusive value="2013-01-01"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="Debitore">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Nome" type="xs:string"/>
												<xs:element name="Cognome" type="xs:string"/>
												<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
