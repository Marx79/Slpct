											<xs:documentation>Da popolare se si tratta di rapporto successivo alla chiusura disposta ex art.118, comma 2, L.F.</xs:documentation>
										</xs:annotation>
									</xs:element>
									<xs:element name="PropostaConcordataria">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="DataTermineAdempimento" type="xs:date"/>
