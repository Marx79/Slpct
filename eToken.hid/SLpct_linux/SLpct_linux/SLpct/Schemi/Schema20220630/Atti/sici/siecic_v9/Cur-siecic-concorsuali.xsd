																</xs:sequence>
															</xs:extension>
														</xs:complexContent>
													</xs:complexType>
												</xs:element>
												<xs:element name="PartecipazioneSocietaria">
													<xs:complexType>
														<xs:complexContent>
															<xs:extension base="LottoMobiliareConcordato">
																<xs:sequence>
