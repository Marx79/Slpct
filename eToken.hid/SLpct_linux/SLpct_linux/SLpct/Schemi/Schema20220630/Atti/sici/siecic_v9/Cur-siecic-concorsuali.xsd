																				<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="Compensi" type="bt:Valuta">
																			<xs:annotation>
																				<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="CancellazioneFormalitaPregiudizievoli" type="bt:Valuta">
