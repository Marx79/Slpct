															<xs:element name="Stima" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>si deve inserire la somma di tutti i crediti del fallito, ma questa volta assumendo non il valore nominale dei crediti, ma gli importi che il curatore ritiene che sia effettivamente possibile realizzare, tenendo conto (sulla base di un giudizio prognostico) delle contestazioni del soggetto che è debitore verso il fallito, degli accertamenti che il curatore deve aver svolto sulla solvibilita' del soggetto debitore, ecc.</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="ImportoRealizzato" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>il curatore deve indicare le somme che ha incassato dai soggetti debitori verso il fallito</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="Passivo">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="ClassificazioneGiuridica">
										<xs:annotation>
											<xs:documentation>Per ciascuna delle 4 categorie giuridiche di crediti (prededucibili, ipotecari, privilegiati, chirografari) il curatore deve inserire:
						-	l’ammontare complessivo dei crediti ammesso 
						-	e, inoltre, l’ammontare complessivo dei crediti ammesso con riserva.
											</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Ammessi">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="CreditiPrededucibili" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Ipotecari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Privilegiati" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Chirografari" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>importo complessivo</xs:documentation>
																</xs:annotation>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="Contabilita">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Entrate">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="TotaleAttivo" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>Non è obbligatorio l'inserimento in quanto corrisponde al totale di tutte le voci di entrate inserite.</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="Uscite">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="TotaleSpese" type="bt:Valuta">
													<xs:annotation>
														<xs:documentation>Non è obbligatorio l'inserimento in quanto corrisponde al totale di tutte le voci di uscite inserite.</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="TotaleRipartito" type="bt:Valuta"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="DepositoRapportoConcordato">
		<xs:annotation>
			<xs:documentation>Deposito rapporto riepilogativo semestrale nel concordato preventivo</xs:documentation>
