													<xs:complexType>
														<xs:sequence>
															<xs:element name="Tipologia" type="TipologiaCrediti">
																<xs:annotation>
																	<xs:documentation>“CREDITI DA AZIONI REVOCATORIE”: è necessario indicare che si tratta solo di crediti pecuniari (non anche ad esempio un credito per la restituzione di un bene  ceduto con atto revocabile), anche se non c’è la sentenza, e che dopo la sentenza, va inserito l’importo accertato ( e non quello preteso dal curatore).</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Complessivo" type="bt:Valuta">
																<xs:annotation>
																	<xs:documentation>si deve inserire la somma di tutti i crediti del fallito, secondo il loro valore nominale</xs:documentation>
																</xs:annotation>
