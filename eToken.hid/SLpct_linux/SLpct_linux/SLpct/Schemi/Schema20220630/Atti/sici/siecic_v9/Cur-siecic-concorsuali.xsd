														</xs:sequence>
													</xs:complexType>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="Mobiliare">
										<xs:complexType>
											<xs:choice minOccurs="0" maxOccurs="unbounded">
												<xs:element name="MobileRegistrato">
													<xs:complexType>
														<xs:complexContent>
															<xs:extension base="LottoMobiliareConcordato">
