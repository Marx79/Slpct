												<xs:element name="Note" type="xs:string" minOccurs="0"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="ClassificazioneGiuridica">
										<xs:annotation>
											<xs:documentation>Per ciascuna delle 4 categorie giuridiche di crediti (prededucibili, ipotecari, privilegiati, chirografari) il curatore deve inserire:
						-	lâ€™ammontare complessivo dei crediti ammesso 
						-	e, inoltre, lâ€™ammontare complessivo dei crediti ammesso con riserva.
					    </xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Ammessi">
