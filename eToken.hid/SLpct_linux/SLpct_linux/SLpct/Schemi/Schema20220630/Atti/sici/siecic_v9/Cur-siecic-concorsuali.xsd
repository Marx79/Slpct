																	<xs:element name="StatoUtilizzo" type="StatoUtilizzo"/>
																</xs:sequence>
															</xs:extension>
														</xs:complexContent>
													</xs:complexType>
												</xs:element>
												<xs:element name="DirittoAutore">
													<xs:complexType>
														<xs:complexContent>
															<xs:extension base="LottoMobiliareConcordato">
																<xs:sequence>
																	<xs:element name="NumeroLotto" type="xs:string"/>
