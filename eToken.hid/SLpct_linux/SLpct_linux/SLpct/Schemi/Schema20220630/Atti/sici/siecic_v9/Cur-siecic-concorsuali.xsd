											<xs:sequence>
												<xs:element name="Nome" type="xs:string"/>
												<xs:element name="Cognome" type="xs:string"/>
												<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
												<xs:element name="DataAssegnazioneFascicolo" type="xs:date">
													<xs:annotation>
														<xs:documentation>data assegnazione fascicolo coincide con la data della sentenza, per il giudice delegato nominato con la sentenza dichiarativa di fallimento; e, invece, coincide con la data del provvedimento collegiale o del presidente del tribunale, per il giudice delegato nominato in data successiva alla sentenza dichiarativa di fallimento</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="DataCessazioneIncarico" type="xs:date"/>
