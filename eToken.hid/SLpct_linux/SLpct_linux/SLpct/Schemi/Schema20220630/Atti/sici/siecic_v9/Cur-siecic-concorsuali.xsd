																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="DataAggiudicazione" type="xs:date" minOccurs="0"/>
															<xs:element name="StatoDiOccupazione">
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:enumeration value="occupato con titolo"/>
