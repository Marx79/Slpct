																	<xs:documentation>numero dei beni che fanno parte del lotto; il numero dei beni non va confuso con il numero delle particelle; un bene è tale, indipendentemente dal numero di particelle catastali che lo descrivono, quando è autonomamente fruibile; quindi, ad esempio, un box, un appartamento, una villetta, un capannone, ecc.</xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="Descrizione" type="xs:string"/>
															<xs:element name="IncaricatoVendita">
																<xs:annotation>
																	<xs:documentation>Il dato deve essere sempre presente, in quanto potrebbe riferirsi anche al curatore</xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="Nome" type="xs:string"/>
																		<xs:element name="Cognome" type="xs:string"/>
																		<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
																		<xs:element name="Qualifica">
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:enumeration value="curatore"/>
																					<xs:enumeration value="professionista delegato"/>
																					<xs:enumeration value="Istituto Vendite Giudiziarie"/>
																					<xs:enumeration value="commissario"/>
																					<xs:enumeration value="soggetto specializzato ex art. 107 comma 1 L.F."/>
																					<xs:enumeration value="ufficiale giudiziario"/>
																					<xs:enumeration value="altro"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="TipoLiquidazione">
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:enumeration value="vendita competitiva"/>
																		<xs:enumeration value="vendita secondo la disciplina del c.p.c."/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:element>
															<xs:element name="Stato" type="StatoLotto"/>
