<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns="http://schemi.processotelematico.giustizia.it/siecic/concorsuali/curatore/v9" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:pt="http://schemi.processotelematico.giustizia.it/tipi/atti/v6" xmlns:at="http://schemi.processotelematico.giustizia.it/tipi/anagrafiche/v4" xmlns:bt="http://schemi.processotelematico.giustizia.it/tipi" xmlns:evt="http://schemi.processotelematico.giustizia.it/siecic/eventi" xmlns:evtCC="http://schemi.processotelematico.giustizia.it/eventi/crisiimpresa" xmlns:st="http://schemi.processotelematico.giustizia.it/siecic/tipibase/v4" targetNamespace="http://schemi.processotelematico.giustizia.it/siecic/concorsuali/curatore/v9" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.1">
	<xs:import namespace="http://schemi.processotelematico.giustizia.it/tipi/atti/v6" schemaLocation="../base_v6/tipi-atti.xsd"/>
	<xs:import namespace="http://schemi.processotelematico.giustizia.it/tipi/anagrafiche/v4" schemaLocation="../base_v4/tipi-anagrafiche.xsd"/>
	<xs:import namespace="http://schemi.processotelematico.giustizia.it/siecic/tipibase/v4" schemaLocation="../base_v4/tipi-base-siecic.xsd"/>
	<xs:import namespace="http://schemi.processotelematico.giustizia.it/siecic/eventi" schemaLocation="../eventi.xsd"/>
	<xs:import namespace="http://schemi.processotelematico.giustizia.it/eventi/crisiimpresa" schemaLocation="../eventi-crisiimpresa.xsd"/>
	<xs:import namespace="http://schemi.processotelematico.giustizia.it/tipi" schemaLocation="../tipi-base.xsd"/>
	<xs:annotation>
		<xs:documentation>ATTI DEL CURATORE</xs:documentation>
		<xs:documentation>Gli atti qui definiti si riferiscono a procedimenti in essere</xs:documentation>
	</xs:annotation>
	<xs:attributeGroup name="CoordinateBancarie">
		<xs:annotation>
			<xs:documentation>Relazione Periodica: Coordinate bancarie</xs:documentation>
		</xs:annotation>
		<xs:attribute name="ABI" type="xs:string" use="required"/>
		<xs:attribute name="CAB" type="xs:string" use="required"/>
		<xs:attribute name="CIN" type="xs:string" use="required"/>
		<xs:attribute name="CC" type="xs:string" use="required"/>
	</xs:attributeGroup>
	<xs:simpleType name="PropostaEsito">
		<xs:annotation>
			<xs:documentation>Ruoli di iscrizione della causa o dell'atto</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="Ammissione"/>
			<xs:enumeration value="Rigetto"/>
			<xs:enumeration value="AmmissioneConRiserva"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:attributeGroup name="PersonaFisica">
		<xs:annotation>
			<xs:documentation>Relazione Periodica: Dati della persona fisica</xs:documentation>
		</xs:annotation>
		<xs:attribute name="Cognome" type="xs:string" use="required"/>
		<xs:attribute name="Nome" type="xs:string" use="required"/>
		<xs:attribute name="CodiceFiscale" use="required">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:length value="16"/>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
		<xs:attribute name="NatoA" type="xs:string" use="required"/>
		<xs:attribute name="DataNascita" type="xs:date" use="required"/>
		<xs:attributeGroup ref="IndirizzoCompleto"/>
	</xs:attributeGroup>
	<xs:attributeGroup name="PersonaGiuridica">
		<xs:annotation>
			<xs:documentation>Relazione Periodica: Dati della persona giuridica</xs:documentation>
		</xs:annotation>
		<xs:attribute name="Denominazione" type="xs:string" use="required"/>
		<xs:attribute name="FormaGiuridica" type="xs:string" use="required"/>
		<xs:attribute name="CodiceFiscale" use="required">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:length value="11"/>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
		<xs:attributeGroup ref="IndirizzoCompleto"/>
	</xs:attributeGroup>
	<xs:attributeGroup name="IndirizzoCompleto">
		<xs:annotation>
			<xs:documentation>Relazione Periodica: Dati di indirizzo</xs:documentation>
		</xs:annotation>
		<xs:attribute name="Indirizzo" type="xs:string" use="required"/>
		<xs:attribute name="CAP" type="xs:string" use="required"/>
		<xs:attribute name="Localita" type="xs:string" use="required"/>
		<xs:attribute name="Provincia" use="required">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:length value="2"/>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
	</xs:attributeGroup>
	<xs:attributeGroup name="TipologieAttivo">
		<xs:annotation>
			<xs:documentation>Relazione Periodica:  Tipologie di attivo</xs:documentation>
		</xs:annotation>
		<xs:attribute name="Stimato" type="xs:float" use="optional"/>
		<xs:attribute name="DaRealizzare" type="xs:float" use="required"/>
		<xs:attribute name="Realizzato" type="xs:float" use="required"/>
	</xs:attributeGroup>
	<xs:attributeGroup name="RG">
		<xs:annotation>
			<xs:documentation>Relazione Periodica: Identificazione Procedura</xs:documentation>
		</xs:annotation>
		<xs:attribute name="Tribunale" type="xs:string" use="required"/>
		<xs:attribute name="Sezione" type="xs:string" use="required"/>
		<xs:attribute name="RuoloGenerale" type="xs:positiveInteger" use="required"/>
		<xs:attribute name="Sub" type="xs:positiveInteger" use="optional"/>
		<xs:attribute name="Anno" type="xs:gYear" use="required"/>
	</xs:attributeGroup>
	<xs:attributeGroup name="InformazioniCause">
		<xs:annotation>
			<xs:documentation>Relazione Periodica: Informazioni cause in corso</xs:documentation>
		</xs:annotation>
		<xs:attribute name="Oggetto" type="xs:string" use="required"/>
		<xs:attribute name="DataUdienza" type="xs:date" use="required"/>
		<xs:attribute name="Fase" use="required">
			<xs:simpleType>
				<xs:restriction base="xs:string">
					<xs:enumeration value="Introduttiva"/>
					<xs:enumeration value="Prove"/>
					<xs:enumeration value="Decisione"/>
				</xs:restriction>
			</xs:simpleType>
		</xs:attribute>
		<xs:attribute name="Valore" type="xs:float" use="required"/>
	</xs:attributeGroup>
	<xs:complexType name="RiferimentoCausa">
		<xs:annotation>
			<xs:documentation>Relazione periodica: Riferimento ad una causa</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="numero" type="xs:nonNegativeInteger"/>
			<xs:element name="anno" type="xs:nonNegativeInteger"/>
		</xs:sequence>
		<xs:attribute name="ufficioGiudiziario" type="xs:string" use="optional"/>
		<xs:attribute name="ufficioSede" type="xs:string" use="optional"/>
	</xs:complexType>
	<xs:complexType name="Filiale">
		<xs:annotation>
			<xs:documentation>Dati filiale bancaria</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="nomeFiliale" type="xs:string"/>
			<xs:element name="banca" type="xs:string" minOccurs="0"/>
			<xs:element name="localita" type="xs:string" minOccurs="0"/>
			<xs:element name="indirizzo" type="xs:string" minOccurs="0"/>
			<xs:element name="fax" type="xs:string" minOccurs="0"/>
			<xs:element name="indirizzoPEC" type="xs:string"/>
			<xs:element name="cap" type="xs:string" minOccurs="0"/>
			<xs:element name="provincia" minOccurs="0">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:length value="2"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="telefono" type="xs:string" minOccurs="0"/>
			<xs:element name="codiceCAB" type="xs:string"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="Libretto">
		<xs:annotation>
			<xs:documentation>Dati libretto</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="numero" type="xs:string"/>
			<xs:element name="intestatario" type="xs:string"/>
			<xs:element name="importoApertura" type="xs:float"/>
			<xs:element name="tipo">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Fruttifero"/>
						<xs:enumeration value="Non Fruttifero"/>
						<xs:enumeration value="Conto Corrente Ordinario"/>
						<xs:enumeration value="Conto Corrente A Pacchetto"/>
						<xs:enumeration value="Conto Corrente Di Base"/>
						<xs:enumeration value="Conto Corrente In Convenzione"/>
						<xs:enumeration value="Conto Corrente Online"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:simpleType name="FormaGiuridicaFallito">
		<xs:restriction base="xs:string">
			<xs:enumeration value="impresa individuale"/>
			<xs:enumeration value="societa' semplice"/>
			<xs:enumeration value="societa' di fatto"/>
			<xs:enumeration value="societa' in nome collettivo"/>
			<xs:enumeration value="societa' in accomandita semplice"/>
			<xs:enumeration value="societa' per azioni"/>
			<xs:enumeration value="societa' in accomandita per azioni"/>
			<xs:enumeration value="societa' a responsabilita' limitata"/>
			<xs:enumeration value="societa' cooperativa"/>
			<xs:enumeration value="altro"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="TipoDirittoProprietario">
		<xs:restriction base="xs:string">
			<xs:enumeration value="piena proprieta'"/>
			<xs:enumeration value="nuda proprieta'"/>
			<xs:enumeration value="usufrutto"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="CategoriaEconomica">
		<xs:restriction base="xs:string">
			<xs:enumeration value="verso soci per finanziamenti"/>
			<xs:enumeration value="verso banche"/>
			<xs:enumeration value="verso altri finanziatori"/>
			<xs:enumeration value="verso fornitori"/>
			<xs:enumeration value="di cui verso imprese controllanti, collegate e controllate"/>
			<xs:enumeration value="verso lavoratori subordinati e para-subordinati"/>
			<xs:enumeration value="verso professionisti"/>
			<xs:enumeration value="verso obbligazionisti"/>
			<xs:enumeration value="debiti tributari, verso istituti di previdenza e di sicurezza sociale"/>
			<xs:enumeration value="di cui per sanzioni"/>
			<xs:enumeration value="altri debiti"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="CategoriaCredito">
		<xs:restriction base="xs:string">
			<xs:enumeration value="prededucibili"/>
			<xs:enumeration value="privilegiati"/>
			<xs:enumeration value="chirografari"/>
			<xs:enumeration value="pignoratizi"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="StatoLotto">
		<xs:restriction base="xs:string">
			<xs:enumeration value="non in vendita"/>
			<xs:enumeration value="aggiudicato"/>
			<xs:enumeration value="trasferito"/>
			<xs:enumeration value="abbandonato"/>
			<xs:enumeration value="in vendita"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="StatoUtilizzo">
		<xs:restriction base="xs:string">
			<xs:enumeration value="libero"/>
			<xs:enumeration value="detenuto con titolo"/>
			<xs:enumeration value="detenuto senza titolo"/>
			<xs:enumeration value="detenuto dal fallito"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="TipologiaCrediti">
		<xs:restriction base="xs:string">
			<xs:enumeration value="crediti verso clienti"/>
			<xs:enumeration value="crediti verso societa"/>
			<xs:enumeration value="crediti verso l'erario"/>
			<xs:enumeration value="crediti da azioni revocatorie e di inefficacia"/>
			<xs:enumeration value="crediti da azioni di responsabilita' in sede civile o penale"/>
			<xs:enumeration value="altri crediti"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="TipologiaCreditiConcordato">
		<xs:restriction base="xs:string">
			<xs:enumeration value="crediti verso clienti"/>
			<xs:enumeration value="crediti verso societa"/>
			<xs:enumeration value="crediti verso l'erario"/>
			<xs:enumeration value="altri crediti"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="AnagraficaCuratore">
		<xs:annotation>
			<xs:documentation>Elemento di anagrafica curatore per relazione periodica. Se specificati più curatori si intende un incarico collegiale.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Curatore" maxOccurs="unbounded">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="Nome" type="xs:string"/>
							<xs:element name="Cognome" type="xs:string"/>
							<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:complexType name="elementoRendiconto">
		<xs:annotation>
			<xs:documentation>Elemento di rendiconto con riferimenti alle voci di contabilita' del fallimento</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element ref="st:importo"/>
			<xs:element name="PDC" type="st:VociPDC" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="LottoMobiliareConcordato">
		<xs:sequence>
			<xs:element name="Descrizione" type="xs:string"/>
			<xs:element name="ValoreStima" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValoreContabile" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValoreStimaProposta" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>valore di stima indicato nella proposta</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValoreAggiudicazione" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="IncaricatoVendita">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Nome" type="xs:string"/>
						<xs:element name="Cognome" type="xs:string"/>
						<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
						<xs:element name="Qualifica">
							<xs:simpleType>
								<xs:restriction base="xs:string">
									<xs:enumeration value="curatore"/>
									<xs:enumeration value="professionista delegato"/>
									<xs:enumeration value="Istituto Vendite Giudiziarie"/>
									<xs:enumeration value="commissario"/>
									<xs:enumeration value="soggetto specializzato ex art. 107 comma 1 L.F."/>
									<xs:enumeration value="ufficiale giudiziario"/>
									<xs:enumeration value="altro"/>
								</xs:restriction>
							</xs:simpleType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Spese">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="ImposteTrasferimento" type="bt:Valuta" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Compensi" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="CancellazioneFormalitaPregiudizievoli" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Altre" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="SpeseOccupazione" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="StatoLotto" type="StatoLotto"/>
			<xs:element name="TipoLiquidazione">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="vendita competitiva"/>
						<xs:enumeration value="vendita secondo la disciplina del c.p.c."/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Note" type="xs:string" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="LottoMobiliare">
		<xs:sequence>
			<xs:element name="Descrizione" type="xs:string"/>
			<xs:element name="ValoreStima" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValoreContabile" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValoreAggiudicazione" type="bt:Valuta">
				<xs:annotation>
					<xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="IncaricatoVendita">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Nome" type="xs:string"/>
						<xs:element name="Cognome" type="xs:string"/>
						<xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
						<xs:element name="Qualifica">
							<xs:simpleType>
								<xs:restriction base="xs:string">
									<xs:enumeration value="curatore"/>
									<xs:enumeration value="professionista delegato"/>
									<xs:enumeration value="Istituto Vendite Giudiziarie"/>
									<xs:enumeration value="commissario"/>
									<xs:enumeration value="soggetto specializzato ex art. 107 comma 1 L.F."/>
									<xs:enumeration value="ufficiale giudiziario"/>
									<xs:enumeration value="altro"/>
								</xs:restriction>
							</xs:simpleType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Spese">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="ImposteTrasferimento" type="bt:Valuta" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Compensi" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="CancellazioneFormalitaPregiudizievoli" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Altre" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="SpeseOccupazione" type="bt:Valuta">
							<xs:annotation>
								<xs:documentation>Dato segretato</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="StatoLotto" type="StatoLotto"/>
			<xs:element name="TipoLiquidazione">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="vendita competitiva"/>
						<xs:enumeration value="vendita secondo la disciplina del c.p.c."/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Note" type="xs:string" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="DepositoSemplice">
		<xs:annotation>
			<xs:documentation>Deposito Atto semplice</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="pt:AttoProcedimentoConc">
					<xs:sequence>
						<xs:element name="deposito">
							<xs:annotation>
								<xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
								<xs:documentation>Specifica la tipologia di atto oggetto di deposito</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:choice>
									<xs:element ref="evt:depositoIstanzaFissazioneVenditaProgrammaLiquidazione"/>
									<xs:element ref="evt:attoNonCodificato"/>
									<xs:element ref="evt:depIstLiquidAcconto"/>
									<xs:element ref="evt:depIstLiquidCompenso"/>
									<xs:element ref="evt:depIstLiquidIntegrazione"/>
									<xs:element ref="evt:depIstEmissMandLiqAcconto"/>
									<xs:element ref="evt:depIstEmissMandLiqCompenso"/>
									<xs:element ref="evt:depIstEmissMandLiqIntegrazione"/>
									<xs:element ref="evt:depIstEmissMandPagGenerico"/>
									<xs:element ref="evt:DepositoElencoCreditori"/>
									<xs:element ref="evt:depositoElencoTitolariDiritti"/>
								</xs:choice>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="DepositoRelazioneIniziale">
		<xs:annotation>
			<xs:documentation>Deposito relazione iniziale ex art. 33 L.F.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
