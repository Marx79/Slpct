<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:pt="http://schemi.processotelematico.giustizia.it/tipi/atti/v6"
           xmlns:at="http://schemi.processotelematico.giustizia.it/tipi/anagrafiche/v4"
           xmlns:bt="http://schemi.processotelematico.giustizia.it/tipi"
           xmlns="http://schemi.processotelematico.giustizia.it/siecic/eventi"
           xmlns:st="http://schemi.processotelematico.giustizia.it/siecic/tipibase/v4"
           targetNamespace="http://schemi.processotelematico.giustizia.it/siecic/eventi" elementFormDefault="qualified"
           attributeFormDefault="unqualified" version="1.7">
    <xs:import namespace="http://schemi.processotelematico.giustizia.it/tipi" schemaLocation="tipi-base.xsd"/>
    <xs:import namespace="http://schemi.processotelematico.giustizia.it/tipi/anagrafiche/v4"
               schemaLocation="base_v4/tipi-anagrafiche.xsd"/>
    <xs:import namespace="http://schemi.processotelematico.giustizia.it/tipi/atti/v6"
               schemaLocation="base_v6/tipi-atti.xsd"/>
    <xs:import namespace="http://schemi.processotelematico.giustizia.it/siecic/tipibase/v4"
               schemaLocation="base_v4/tipi-base-siecic.xsd"/>
    <xs:annotation>
        <xs:documentation>Eventi correlati all'estensione del PCT alle procedure esecutive individuali e concorsuali.
        </xs:documentation>
    </xs:annotation>
    <xs:element name="DepositoSostituzioneEsperto">
        <xs:annotation>
            <xs:documentation>Deposito Sostituzione Esperto</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento">
                    <xs:sequence>
                        <xs:element name="cfEsperto" type="bt:CodiceFiscale">
                            <xs:annotation>
                                <xs:documentation>codice fiscale esperto</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="cognome" type="xs:string" minOccurs="0">
                            <xs:annotation>
                                <xs:documentation>cognome esperto nuova anagrafica</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="nome" type="xs:string" minOccurs="0">
                            <xs:annotation>
                                <xs:documentation>nome esperto nuova anagrafica</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="viaPiazza" type="xs:string" minOccurs="0">
                            <xs:annotation>
                                <xs:documentation>via esperto nuova anagrafica</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="dataNascita" type="xs:date" minOccurs="0"/>
                        <xs:element name="luogoNascita" type="xs:string" minOccurs="0"/>
                        <xs:element name="cap" type="xs:string" minOccurs="0"/>
                        <xs:element name="citta" type="xs:string" minOccurs="0"/>
                        <xs:element name="provincia" type="xs:string" minOccurs="0"/>
                        <xs:element name="telefono" type="xs:string" minOccurs="0"/>
                        <xs:element name="pec" type="xs:string" minOccurs="0"/>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="IstanzaRevocaAusiliario">
        <xs:annotation>
            <xs:documentation>Istanza Revoca Ausiliario</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento">
                    <xs:sequence>
                        <xs:element name="Parte" type="at:Parte" minOccurs="0"/>
                        <xs:element name="Avvocato" type="at:Avvocato" minOccurs="0"/>
                        <xs:element name="TipoParte">
                            <xs:simpleType>
                                <xs:restriction base="xs:string">
                                    <xs:enumeration value="Creditore"/>
                                    <xs:enumeration value="Terzo"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="nominaAusiliario">
        <xs:annotation>
            <xs:documentation>Nomina Ausiliario</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento"/>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="DecretoSostituzioneAusiliario">
        <xs:annotation>
            <xs:documentation>Decreto Sostituzione Ausiliario</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento">
                    <xs:sequence>
                        <xs:element name="motivazioni" minOccurs="0">
                            <xs:simpleType>
                                <xs:restriction base="xs:normalizedString">
                                    <xs:enumeration value="Dimissioni"/>
                                    <xs:enumeration value="Surroga"/>
                                    <xs:enumeration value="Rinunzia"/>
                                    <xs:enumeration value="Altro"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="altraMotivazione" minOccurs="0"/>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="FissazioneUdienzaOmologa">
        <xs:annotation>
            <xs:documentation>Fissazione Udienza Omologa con Termine per opposizione</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento">
                    <xs:choice>
                        <xs:element name="datiAusiliario" minOccurs="0">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="cognome" type="xs:string">
                                        <xs:annotation>
                                            <xs:documentation>cognome nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="nome" type="xs:string">
                                        <xs:annotation>
                                            <xs:documentation>nome nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="codiceFiscale" type="bt:CodiceFiscale"/>
                                    <xs:element name="viaPiazza" type="xs:string" minOccurs="0">
                                        <xs:annotation>
                                            <xs:documentation>via nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="citta" type="xs:string" minOccurs="0">
                                        <xs:annotation>
                                            <xs:documentation>citta nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="provincia" type="xs:string" minOccurs="0">
                                        <xs:annotation>
                                            <xs:documentation>provincia nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="cap" type="xs:string" minOccurs="0">
                                        <xs:annotation>
                                            <xs:documentation>cap nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="PEC" type="xs:string">
                                        <xs:annotation>
                                            <xs:documentation>pec nuova anagrafica</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="codiceFiscale" type="bt:CodiceFiscale" minOccurs="0">
                            <xs:annotation>
                                <xs:documentation>codice fiscale anagrafato</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                    </xs:choice>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="DepositoRinunciaEsperto" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Rinuncia Esperto</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="RicorsoProponenteDenunciaDeb" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Ricorso Proponente (185 V C. LF)</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="PrAusiliario" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Parere Ausiliario</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="PrEsperto" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Parere Esperto</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="RelazioneTribunaleInadempimentiDebitore" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Relazione al Tribunale Inadampienti Debitore</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="RelazioneFinaleEsperto" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Relazione Finale Esperto</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="RevocaAusiliario" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Revoca Ausiliario</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="Inefficacia" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Inefficacia</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DecretoOmologazioneConcordSemplificato">
        <xs:annotation>
            <xs:documentation>Decreto di Omologazione Concordato Semplificato</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento">
                    <xs:sequence>
                        <xs:element name="codiceFiscale" type="bt:CodiceFiscale" maxOccurs="unbounded"/>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="RichiestaParereEsperto" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Richiesta Parere Esperto</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="RigProRevAusiliario" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Richiesta Parere Esperto</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="RinunciaIncaricoAusiliario" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Rinuncia Ausiliario</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoPianoLiquidazione" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Piano di omologazione</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoRelSitPatEcoFin" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Relazione sulla Situazione Patrimoniale Economica e Finanziaria
            </xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoStatoAnaEstimativoAttivita" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Stato Analitico ed Estimativo Attivita</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoElencoCreditori" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Elenco Creditori</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoElencoTitDirRealiPersonali" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Elenco dei Titolari Diritti Reali o Personali</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoStimaValBeniCredSoci" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Deposito Stima dei Beni del Valore dei Creditori dei Soci</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:element name="DepositoInformativaLiquidatore" type="pt:IstanzaEvento">
        <xs:annotation>
            <xs:documentation>Informativa Esito Vendite</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:complexType name="DecretoChiusura">
        <xs:annotation>
            <xs:documentation>Decreti di chiusura ex artt 102 e 118</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="pt:IstanzaEvento">
                <xs:attribute name="Tipologia" use="required">
                    <xs:simpleType>
                        <xs:restriction base="xs:string">
                            <xs:enumeration value="MancateInsinuazioni"/>
                            <xs:enumeration value="ChiusuraAnticipata"/>
                            <xs:enumeration value="CompiutaRipartizioneFinale"/>
                            <xs:enumeration value="InsufficienzaAttivo"/>
                            <xs:enumeration value="InsufficienzaRealizzo"/>
                        </xs:restriction>
                    </xs:simpleType>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:simpleType name="TipoParteAttoGenerico">
        <xs:restriction base="xs:string">
            <xs:enumeration value="ANCRED">
                <xs:annotation>
                    <xs:documentation>Creditore</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="ANDEB">
                <xs:annotation>
                    <xs:documentation>Debitore</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="ANSOC">
                <xs:annotation>
                    <xs:documentation>Socio Debitore</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="ANPM">
                <xs:annotation>
                    <xs:documentation>P.M.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="ANCUR">
                <xs:annotation>
                    <xs:documentation>Curatore</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="CDC">
                <xs:annotation>
                    <xs:documentation>Comitato dei Creditori</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>
    <xs:complexType name="EventiDelegato">
        <xs:annotation>
            <xs:documentation>Operazioni delegate</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="pt:IstanzaEvento">
                <xs:attribute name="lotto" type="xs:string" use="required">
                    <xs:annotation>
                        <xs:documentation>Identificatico del lotto al quale si riferisce l'evento, deve fare riferimento
                            al numero del lotto nel sistema SIECIC se il lotto è predisposto.
                        </xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="Sospensione">
        <xs:annotation>
            <xs:documentation>Evento di sospensione</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="pt:IstanzaEvento">
                <xs:attribute name="dataTermine" type="xs:date"/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="FissazioneUdienza">
        <xs:annotation>
            <xs:documentation>Eventi di fissazione udienza</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="pt:IstanzaEvento">
                <xs:attribute name="data" type="xs:dateTime" use="required">
                    <xs:annotation>
                        <xs:documentation>Data fissata per l'udienza da tenere</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="DataUdienza">
        <xs:simpleContent>
            <xs:extension base="xs:dateTime">
                <xs:attribute name="straordinaria" type="xs:boolean" use="optional" default="false"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:complexType name="RinvioUdienza">
        <xs:annotation>
            <xs:documentation>Evento di rinvio udienza</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="FissazioneUdienza">
                <xs:attribute name="dataUdienza" type="xs:dateTime" use="required">
                    <xs:annotation>
                        <xs:documentation>Data udienza da rinviare</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="SostituzioneSoggetto">
        <xs:annotation>
            <xs:documentation>Generico evento di sostituzione soggetto coinvolto nel procedimento</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="riferimento" type="at:RiferimentoSoggetto" minOccurs="0">
                <xs:annotation>
                    <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="DepositoAtto">
        <xs:annotation>
            <xs:documentation>Evento di generico deposito di atti della parte</xs:documentation>
        </xs:annotation>
        <xs:all>
            <xs:element name="parte" type="at:RiferimentoSoggetto" minOccurs="0">
                <xs:annotation>
                    <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                </xs:annotation>
            </xs:element>
        </xs:all>
    </xs:complexType>
    <xs:complexType name="DepositoPianoRipartoParziale">
        <xs:annotation>
            <xs:documentation>Deposito piano riparto parziale con specifica dell'accantonamento</xs:documentation>
        </xs:annotation>
        <xs:attribute name="accantonamento" type="bt:Valuta" use="required"/>
    </xs:complexType>
    <xs:complexType name="MotivoRimessionePresidente">
        <xs:sequence>
            <xs:element name="motivo" type="xs:string" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <xs:element name="emissioneMandatoPagSpeseProcedura">
        <xs:annotation>
            <xs:documentation>Emissione Mandato Pagamento Spese Procedura</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:IstanzaEvento">
                    <xs:sequence>
                        <xs:element name="importo" type="bt:Valuta"/>
                        <xs:element name="IBAN" type="xs:string"/>
                        <xs:element name="idLiq" type="xs:string"/>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="depositoIstanza41TUB" type="DepositoAtto">
        <xs:annotation>
            <xs:documentation>Istanza ex. art. 41 TUB</xs:documentation>
        </xs:annotation>
    </xs:element>
