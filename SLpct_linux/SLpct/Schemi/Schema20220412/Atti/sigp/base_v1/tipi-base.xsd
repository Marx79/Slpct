<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns="http://schemi.processotelematico.giustizia.it/sigp/tipi/v1"
           targetNamespace="http://schemi.processotelematico.giustizia.it/sigp/tipi/v1"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">
	<xs:annotation>
		<xs:documentation>Tipi primitivi utilizzati nella definizione degli schemi</xs:documentation>
	</xs:annotation>
	<xs:complexType name="EmptyElement">
		<xs:complexContent>
			<xs:restriction base="xs:anyType"/>
		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="UfficioTelematico">
		<xs:annotation>
			<xs:documentation>Elenco uffici abilitati al processo telematico</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:whiteSpace value="collapse"/>
			<xs:maxLength value="15"/>
			<xs:pattern value="[0-9A-Z]+"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Valuta">
		<xs:annotation>
			<xs:documentation>Formato numerico accettato per l'indicazione di tutti gli importi</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:float">
			<xs:whiteSpace value="collapse"/>
			<xs:pattern value="\p{Nd}*(\.\p{Nd}{2,2})?"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="Percentuale">
		<xs:annotation>
			<xs:documentation>Tipologia per il valore espresso in percentuale</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:float">
			<xs:minInclusive value="+0"/>
			<xs:maxInclusive value="100"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="CodiceFiscale">
		<xs:annotation>
			<xs:documentation>Codice fiscale, utilizzato per definire ed all'occorrenza identificare univocamente un soggetto coinvolto nel procedimento</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:whiteSpace value="collapse"/>
			<xs:pattern value="(\p{Nd}|\p{L}){14,16}"/>
			<xs:pattern value="[0-9]{11,11}"/>
			<xs:pattern value="(EX:[0-9]{13,13})"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="CodiceUfficioPostale">
		<xs:annotation>
			<xs:documentation>Codice idenitificativo dell'ufficio postale, utilizzato per l'dentificazione di di bollettini di pagamento</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="\d{2,2}/\d{3,3}"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="CodiceVCY">
		<xs:annotation>
			<xs:documentation>Codice identificativo del pagamento tramite bollettino postale</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="\d{4,4}"/>
		</xs:restriction>
	</xs:simpleType>
