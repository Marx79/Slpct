					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="DL_196-2003_art_52_comma_1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>True se la parte ritiene che debba essere concessa la privacy per il DL 196/2003 Art. 52, comma 1</xs:documentation>
