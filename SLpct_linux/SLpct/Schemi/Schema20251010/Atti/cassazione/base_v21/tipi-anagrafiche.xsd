							</xs:complexContent>
						</xs:complexType>
					</xs:element>
					<xs:element name="cassazionista" type="xs:boolean" minOccurs="0"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
