                                                                            <xs:documentation>quando non è compilato, dovra' essere obbligatoriamente presente il campo “ragioni della mancata emissione del decreto di trasferimento”</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="ragioniMancataEmissDecrTrasf" type="xs:string" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>presente quando non è compilato DataDecretoTrasferimento</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="DataCancTrascrIscri" type="xs:date" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation> quando non è compilato, dovra' essere obbligatoriamente presente il campo “ragioni della mancata cancellazione trascrizioni e iscrizioni pregiudizievoli”</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="ragioniMancataCancTrascrIscri" type="xs:string" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>presente quando non è compilato DataCancTrascIscri</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="TentativiVendita" minOccurs="0" maxOccurs="unbounded">
                                                                        <xs:complexType>
                                                                            <xs:sequence>
                                                                                <xs:element name="NumeroTentativo"/>
                                                                                <xs:element name="DataVendita" type="xs:date"/>
