                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:element name="DepositoRapportoSintetico">
        <xs:annotation>
            <xs:documentation>Deposito rapporto riepilogativo  sintetico</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento">
                    <xs:sequence>
                        <xs:element name="Attivo">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Immobiliare">
                                        <xs:complexType>
                                            <xs:sequence minOccurs="0" maxOccurs="unbounded">
                                                <xs:element name="Lotto">
                                                    <xs:complexType>
                                                        <xs:sequence>
                                                            <xs:element name="Numero" type="xs:string">
                                                                <xs:annotation>
                                                                    <xs:documentation>nr. identificativo del lotto</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="Stato" type="StatoLotto"/>
                                                            <xs:element name="ValoreContabileDiStima" type="bt:Valuta">
                                                                <xs:annotation>
                                                                    <xs:documentation>Valorizzare obbligatoriamente e da specificare diverso da zero per lotto in stato aggiudicato, in vendita e trasferito, altrimenti specificare motivazione nel campo Note</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="ImportoAggiudicazione" type="bt:Valuta">
                                                                <xs:annotation>
                                                                    <xs:documentation>Valorizzare obbligatoriamente per lotto in stato aggiudicato e trasferito, se valorizzato a zero specificare motivazione nel campo Note</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="DescrizioneLotto" type="DescrizioneLotto">
                                                                <xs:annotation>
                                                                    <xs:documentation>se il lotto si compone di più immobili, occorre inserire la descrizione dell’immobile di più elevato valore</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="NumeroBeni" type="xs:int">
                                                                <xs:annotation>
                                                                    <xs:documentation>per pluralita' di immobili non si deve intendere l’esistenza di più particelle catastali, ma di più unita' immobiliari autonomamente godibili, indipendentemente dal numero di particelle catastali</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="Beni" maxOccurs="unbounded">
                                                                <xs:annotation>
                                                                    <xs:documentation>Elenco dei beni che compongono il lotto</xs:documentation>
                                                                </xs:annotation>
                                                                <xs:complexType>
                                                                    <xs:sequence>
                                                                        <xs:element name="DatiBene">
                                                                            <xs:complexType>
                                                                                <xs:sequence>
                                                                                    <xs:element name="Descrizione" type="xs:string"/>
                                                                                    <xs:element name="Stima" type="bt:Valuta"/>
                                                                                </xs:sequence>
                                                                            </xs:complexType>
                                                                        </xs:element>
                                                                    </xs:sequence>
                                                                </xs:complexType>
                                                            </xs:element>
                                                            <xs:element name="TentativiVendita">
                                                                <xs:complexType>
                                                                    <xs:sequence>
                                                                        <xs:element name="NumeroTentativo"/>
                                                                        <xs:element name="PrezzoBase" type="bt:Valuta">
                                                                            <xs:annotation>
                                                                                <xs:documentation>per prezzo base si intende quello stabilito dal giudice o dal professionista delegato e non l'offerta minima</xs:documentation>
                                                                            </xs:annotation>
                                                                        </xs:element>
                                                                    </xs:sequence>
                                                                </xs:complexType>
                                                            </xs:element>
                                                            <xs:element name="DataAggiudicazione" type="xs:date"/>
                                                        </xs:sequence>
                                                    </xs:complexType>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="Crediti">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="DatiGenerali">
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="NumeroCreditori" type="xs:int"/>
                                                <xs:element name="ImportoTotaleCrediti" type="bt:Valuta">
                                                    <xs:annotation>
                                                        <xs:documentation>dato dalla somma degli importi dei crediti definiti nell’elenco dei creditori</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                    <xs:element name="ClassificazioneGiuridica" minOccurs="3" maxOccurs="3">
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="CategoriaCredito" type="CategoriaCredito">
                                                    <xs:annotation>
                                                        <xs:documentation>Categoria credito</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="ImpComplessivo" type="bt:Valuta"/>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="Contabilita">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="EntrateUscite">
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="Entrate">
                                                    <xs:complexType>
                                                        <xs:sequence>
                                                            <xs:element name="TotaleAttivo" type="bt:Valuta">
                                                                <xs:annotation>
                                                                    <xs:documentation>Non è obbligatorio l'inserimento in quanto corrisponde al totale di tutte le voci di entrate inserite.</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                        </xs:sequence>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="Uscite">
                                                    <xs:complexType>
                                                        <xs:sequence>
                                                            <xs:element name="TotaleSpese" type="bt:Valuta">
                                                                <xs:annotation>
                                                                    <xs:documentation>Non è obbligatorio l'inserimento in quanto corrisponde al totale di tutte le voci di uscite inserite.</xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                        </xs:sequence>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="Saldo" type="bt:Valuta">
                                                    <xs:annotation>
                                                        <xs:documentation>dato da Attivo – Uscite</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="SaldoRipartito" type="bt:Valuta">
                                                    <xs:annotation>
                                                        <xs:documentation>dato da Attivo – Uscite + Totale uscite di cui anticipate</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:simpleType name="TipologiaAttivita">
        <xs:annotation>
            <xs:documentation>Tipi di attivita' del delegato</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Vendita"/>
            <xs:enumeration value="Assegnazione"/>
            <xs:enumeration value="Trasferimento"/>
            <xs:enumeration value="Distribuzione"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="Privilegio">
        <xs:annotation>
            <xs:documentation>Tipi privilegio del creditore</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Ipoteca"/>
            <xs:enumeration value="Privilegio speciale ex art. 2772 cc"/>
            <xs:enumeration value="Privilegio speciale ex art. 2774 cc"/>
            <xs:enumeration value="Privilegio speciale ex art. 2774 cc"/>
            <xs:enumeration value="Privilegio speciale ex art. 2775 cc"/>
            <xs:enumeration value="Privilegio speciale ex art. 2775bis cc"/>
            <xs:enumeration value="Privilegio sussidiario ex art. 2776 cc"/>
            <xs:enumeration value="Chirografario tempestivo"/>
            <xs:enumeration value="chirografario tardivo ex art. 565 cpc"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="TipoPrivilegio">
        <xs:annotation>
            <xs:documentation>Tipi Atti introduttivi per le Successioni</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Istanza"/>
            <xs:enumeration value="AttoGiudiziario"/>
            <xs:enumeration value="AttoNotarile"/>
            <xs:enumeration value="Segnalazione"/>
            <xs:enumeration value="Dichiarazione"/>
            <xs:enumeration value="Altro"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:element name="DepositoSemplice">
        <xs:annotation>
            <xs:documentation>Deposito Atto semplice</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento">
                    <xs:sequence>
                        <xs:element name="deposito">
                            <xs:annotation>
                                <xs:documentation>Specifica la tipologia di atto oggetto di deposito</xs:documentation>
                                <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:choice>
                                    <xs:element ref="evt:relazionePeriodicaDelegato"/>
                                    <xs:element ref="evt:avvisoVendita"/>
                                    <xs:element ref="evt:verbaleAggiudicazione"/>
                                    <xs:element ref="evt:depositoPrezzo"/>
                                    <xs:element ref="evt:istanzaRevocaDecadenzaAggiudicatario"/>
                                    <xs:element ref="evt:attoNonCodificato"/>
                                    <xs:element ref="evt:istanzaIntegrazioneSpese"/>
                                    <xs:element ref="evt:istanzaLiquidazioneProfessionistaDelegato"/>
                                    <xs:element ref="evt:verbaleAstaDeserta"/>
                                    <xs:element ref="evt:rinunciaIncarico"/>
                                    <xs:element ref="evt:depIstEmissMandPagGenerico"/>
                                </xs:choice>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="MinutaDecreto">
        <xs:annotation>
            <xs:documentation>Deposito Atto minuta decreto di trasferimento</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento">
                    <xs:sequence>
                        <xs:element name="lotto" type="xs:string" nillable="false">
                            <xs:annotation>
                                <xs:documentation>Specifica del numero di lotto al quale si riferisce (se è un evento di lotto)</xs:documentation>
                                <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                            </xs:annotation>
                        </xs:element>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="PropostaProgetto">
        <xs:annotation>
            <xs:documentation>Deposito Atto proposta progetto di distribuzione</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento"/>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="AggiudicazioneLotto">
        <xs:annotation>
            <xs:documentation>Aggiudicazione lotto (verbale di vendita)</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento">
                    <xs:sequence>
                        <xs:element name="Lotto" type="xs:positiveInteger">
                            <xs:annotation>
                                <xs:documentation>Ideintificazione numerica del lotto oggetto di aggiudicazione</xs:documentation>
                                <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                            </xs:annotation>
                        </xs:element>
                        <xs:choice>
                            <xs:element name="SenzaIncanto">
                                <xs:annotation>
                                    <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                                </xs:annotation>
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="ImportoAumento" type="bt:Valuta">
                                            <xs:annotation>
                                                <xs:documentation>Importo fissato per le offerte in aumento</xs:documentation>
                                            </xs:annotation>
                                        </xs:element>
                                        <xs:element name="Offerte" maxOccurs="unbounded">
                                            <xs:complexType>
                                                <xs:sequence>
                                                    <xs:element ref="st:importo"/>
                                                    <xs:element name="Cauzione" type="bt:Valuta"/>
                                                    <xs:element name="Spese" type="bt:Valuta" nillable="true"/>
                                                    <xs:element name="Offerente" type="at:Soggetto"/>
                                                </xs:sequence>
                                            </xs:complexType>
                                        </xs:element>
                                        <xs:element name="Aggiudicatario" type="at:RiferimentoSoggetto">
                                            <xs:annotation>
                                                <xs:documentation>I dati dell'aggiudicatario sono dedotti dai dati degli offerenti, qui viene riportato il solo codice fiscale che deve avere una ed una sola occorrenza nell'insieme degli offerenti</xs:documentation>
                                            </xs:annotation>
                                        </xs:element>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="ConIncanto">
                                <xs:annotation>
                                    <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                                </xs:annotation>
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="BaseAsta" type="bt:Valuta"/>
                                        <xs:element name="ImportoAumento" type="bt:Valuta">
                                            <xs:annotation>
                                                <xs:documentation>Importo fissato per le offerte in aumento</xs:documentation>
                                            </xs:annotation>
                                        </xs:element>
                                        <xs:element ref="st:importo"/>
                                        <xs:element name="Cauzione" type="bt:Valuta"/>
                                        <xs:element name="Spese" type="bt:Valuta" nillable="true"/>
                                        <xs:element name="Aggiudicatario" type="at:Soggetto"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:choice>
                        <xs:element name="TermineConguaglio" type="xs:date">
                            <xs:annotation>
                                <xs:documentation>Termine per il versamento del conguaglio</xs:documentation>
                                <xs:appinfo source="http://www.giustizia.it/gl/sgr"/>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="TermineDecreto" type="xs:date" nillable="true" minOccurs="0">
                            <xs:annotation>
                                <xs:documentation>Termine per l’emissione del decreto di trasferimento</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="ProgettoDistribuzione">
        <xs:annotation>
            <xs:documentation>Decreto di esecutivita' progetto di distribuzione</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento">
                    <xs:sequence>
                        <xs:element name="dispositivo">
                            <xs:complexType>
                                <xs:choice>
                                    <xs:element ref="evt:accoglimentoPianoRipartoParziale"/>
                                    <xs:element ref="evt:accoglimentoPianoRiparto"/>
                                </xs:choice>
                            </xs:complexType>
                        </xs:element>
                        <xs:element ref="st:dettagliRiparto" minOccurs="0"/>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="DepositoAttestatoPrestazioneEnergetica">
        <xs:annotation>
            <xs:documentation>Deposito attestato prestazione energetica</xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="pt:AttoProcedimento">
                    <xs:sequence>
                        <xs:element name="beneImmobile" type="st:BeneImmobile" nillable="false">
                            <xs:annotation>
                                <xs:documentation>Specifica del bene immobile da liberare</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element ref="st:certificazioneEnergetica"/>
                    </xs:sequence>
                </xs:extension>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    <xs:element name="MinutaDecretoTrasferimento">
        <xs:annotation>
            <xs:documentation>Minuta decreto trasferimento</xs:documentation>
        </xs:annotation>
    </xs:element>
</xs:schema>

