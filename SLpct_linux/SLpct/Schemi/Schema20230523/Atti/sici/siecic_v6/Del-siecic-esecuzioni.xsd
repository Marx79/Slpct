                                                                <xs:sequence>
                                                                    <xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="Importo" type="bt:Valuta"/>
                                                        <xs:element name="DataPagamento" type="xs:date"/>
                                                    </xs:sequence>
                                                </xs:complexType>
