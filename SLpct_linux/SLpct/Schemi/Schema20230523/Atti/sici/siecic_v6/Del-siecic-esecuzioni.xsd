                        <xs:keyref name="PK_BENE_DEB_CRED_MOB" refer="PK_CRED_MOB">
                            <xs:selector xpath="Attivo/Mobiliare/Lotto/Beni/DatiBene/Debitore/Creditor"/>
                            <xs:field xpath="CodiceFiscale"/>
