                                                                    <xs:element name="Causale" type="xs:string"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="SommaConfiscata" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>conversione pignoramento</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="Note" type="xs:string" minOccurs="0"/>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                        </xs:sequence>
                                    </xs:complexType>
                                </xs:element>
                                <xs:element name="Crediti">
                                    <xs:complexType>
                                        <xs:sequence>
                                            <xs:element name="DatiGenerali">
                                                <xs:complexType>
                                                    <xs:sequence>
