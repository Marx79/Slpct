                                                                    <xs:element name="ImposteETasseTrasferimento" type="bt:Valuta" minOccurs="0"/>
                                                                    <xs:element name="SpeseDiLiquidazione">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Dato segretato: spese (Di cui per cancellazione formalita' pregiudizievoli, Di cui per altre spese)</xs:documentation>
                                                                        </xs:annotation>
                                                                        <xs:complexType>
                                                                            <xs:sequence>
                                                                                <xs:element name="CancellazionePregiudizievoli" type="bt:Valuta">
                                                                                    <xs:annotation>
                                                                                        <xs:documentation>di cui per cancellazione formalita' pregiudizievoli. Nel caso non ci siano state spese inserire 0.00</xs:documentation>
                                                                                    </xs:annotation>
                                                                                </xs:element>
                                                                                <xs:element name="AltreSpese" type="bt:Valuta">
                                                                                    <xs:annotation>
                                                                                        <xs:documentation>di cui per altre spese. Nel caso non ci siano state spese inserire 0.00</xs:documentation>
                                                                                    </xs:annotation>
                                                                                </xs:element>
                                                                            </xs:sequence>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="DataAggiudicazione" type="xs:date" minOccurs="0"/>
                                                                    <xs:element name="ValoreAggiudicazione">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Valore obbligatorio, nel caso il lotto non sia nello stato aggiudicato andra' inserito il valore 0.00</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="DataVersamentoPrezzo" type="xs:date" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Data versamento prezzo/conguaglio (verbale di vendita)</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="Note" type="xs:string" minOccurs="0"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                            <xs:element name="Altro">
                                                <xs:complexType>
                                                    <xs:sequence>
                                                        <xs:element name="Rendita" maxOccurs="unbounded">
                                                            <xs:annotation>
                                                                <xs:documentation>Per “rendita” s’intendono canoni di locazione e/o affitto.Se non ci sono rendite, il delegato indichera' “0,00”</xs:documentation>
                                                            </xs:annotation>
                                                            <xs:complexType>
                                                                <xs:sequence>
                                                                    <xs:element name="NumeroLotto" type="xs:string"/>
                                                                    <xs:element name="Rendita" type="bt:Valuta"/>
