                                                                                    </xs:annotation>
                                                                                </xs:element>
                                                                                <xs:element name="AltreSpese" type="bt:Valuta">
                                                                                    <xs:annotation>
                                                                                        <xs:documentation>di cui per altre spese</xs:documentation>
                                                                                    </xs:annotation>
                                                                                </xs:element>
                                                                            </xs:sequence>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="DataAggiudicazione" type="xs:date" minOccurs="0"/>
                                                                    <xs:element name="StatoDiOccupazione">
                                                                        <xs:annotation>
                                                                            <xs:documentation>- se è valorizzato con “occupato senza titolo dall’esecutato” o con “occupato senza titolo da terzi”, è obbligatorio compilare i campi EmessoOrdineLiberazione e DebitoAutorizzatoPermanere  -se è valorizzato con “occupato con titolo”, è obbligatorio compilare i campi “data titolo”,“natura del titolo” e “scadenza del titolo”
                                                                            </xs:documentation>
                                                                        </xs:annotation>
                                                                        <xs:simpleType>
                                                                            <xs:restriction base="xs:string">
                                                                                <xs:enumeration value="Libero"/>
                                                                                <xs:enumeration value="In corso di liberazione"/>
                                                                                <xs:enumeration value="Occupato senza titolo dall’esecutato"/>
                                                                                <xs:enumeration value="Occupato senza titolo da terzi"/>
                                                                                <xs:enumeration value="Occupato con titolo"/>
                                                                            </xs:restriction>
                                                                        </xs:simpleType>
                                                                    </xs:element>
                                                                    <xs:element name="EmessoOrdineLiberazione" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Nel caso sia stato emesso un ordine di liberazione (e quindi il tag sia valorizzato a true) devono essere obbligatoriamente valorizzate sia la DataOrdineLiberazione che DataInizioAttivita</xs:documentation>
                                                                        </xs:annotation>
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="xs:boolean">
                                                                                    <xs:attribute name="DataOrdineLiberazione" type="xs:date"/>
                                                                                    <xs:attribute name="DataInizioAttivita" type="xs:date">
                                                                                        <xs:annotation>
                                                                                            <xs:documentation>per 'data inizio attivita'' si intende la prima comunicazione inviata al soggetto che occupa l’immobile con l’invito a lasciarlo libero</xs:documentation>
                                                                                        </xs:annotation>
                                                                                    </xs:attribute>
                                                                                    <xs:attribute name="DataLiberazioneEseguita" type="xs:date"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="DebitoreAutorizzatoPermanere" type="xs:boolean" minOccurs="0"/>
                                                                    <xs:element name="DataTitolo" type="xs:date" minOccurs="0"/>
                                                                    <xs:element name="NaturaTitolo" type="xs:string" minOccurs="0"/>
                                                                    <xs:element name="ScadenzaTitolo" type="xs:date" minOccurs="0"/>
                                                                    <xs:element name="DataVersamentoPrezzo" type="xs:date" minOccurs="0"/>
                                                                    <xs:element name="ImportoVersatoAggiudicatario" type="bt:Valuta" minOccurs="0"/>
                                                                    <xs:element name="DataDepositoProgDistr" type="xs:date" minOccurs="0">
