                                                                                                                    <xs:enumeration value="nuda proprietà"/>
                                                                                                                    <xs:enumeration value="usufrutto"/>
                                                                                                                    <xs:enumeration value="superficie"/>
                                                                                                                    <xs:enumeration value="servitù"/>
                                                                                                                </xs:restriction>
