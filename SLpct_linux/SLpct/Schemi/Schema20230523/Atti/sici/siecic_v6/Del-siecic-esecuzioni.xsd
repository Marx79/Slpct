                                                                                    <xs:annotation>
                                                                                        <xs:documentation>per prezzo base si intende quello stabilito dal giudice o dal professionista delegato e non l'offerta minima</xs:documentation>
                                                                                    </xs:annotation>
                                                                                </xs:element>
                                                                                <xs:element name="PercentualeRibasso" type="bt:Percentuale"/>
                                                                                <xs:element name="CognomeIncaricato" type="xs:string"/>
                                                                                <xs:element name="CodFiscIncaricato" type="bt:CodiceFiscale"/>
                                                                                <xs:element name="NomeIncaricato" type="xs:string"/>
                                                                                <xs:element name="RestituzioneAtti" type="xs:boolean">
                                                                                    <xs:annotation>
                                                                                        <xs:documentation>Segnalazione di asta andata deserta</xs:documentation>
                                                                                    </xs:annotation>
                                                                                </xs:element>
                                                                                <xs:element name="VenditaTelematica" type="xs:string"/>
                                                                                <xs:element name="TipoVenditaTelematica" type="xs:string"/>
                                                                                <xs:element name="GestioneVenditaTelematica" type="xs:string"/>
                                                                                <xs:element name="AccettazioneGestore" type="xs:boolean"/>
                                                                                <xs:element name="DataAccettazioneGestore" type="xs:date"/>
                                                                            </xs:sequence>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="ImposteETasseTrasferimento" type="bt:Valuta" minOccurs="0"/>
                                                                    <xs:element name="SpeseDiLiquidazione">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Dato segretato: spese (Di cui per cancellazione formalita' pregiudizievoli, Di cui per altre spese)</xs:documentation>
                                                                        </xs:annotation>
                                                                        <xs:complexType>
                                                                            <xs:sequence>
                                                                                <xs:element name="CancellazionePregiudizievoli" type="bt:Valuta">
