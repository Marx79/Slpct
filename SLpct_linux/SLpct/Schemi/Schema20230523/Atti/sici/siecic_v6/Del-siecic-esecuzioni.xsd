                                                                            <xs:documentation>Data trasmissione al giudice della bozza del decreto di trasferimento</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="ImportoRipartitoCreditore" type="bt:Valuta" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Importo complessivamente ripartito ai creditori</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="DataUdieApprProgDistr" type="xs:date" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>data dell’udienza di approvazione del progetto di distribuzione</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="DataUltimoPagCred" type="xs:date" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>data dell’ultimo pagamento ai creditori</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                    <xs:element name="Note" type="xs:string" minOccurs="0"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                            <xs:element name="Altro">
                                                <xs:complexType>
                                                    <xs:sequence>
                                                        <xs:element name="Rendita" maxOccurs="unbounded">
                                                            <xs:annotation>
                                                                <xs:documentation>Per “rendita” s’intendono canoni di locazione e/o affitto.Se non ci sono rendite, il delegato indichera' “0,00”</xs:documentation>
                                                            </xs:annotation>
                                                            <xs:complexType>
                                                                <xs:sequence>
                                                                    <xs:element name="NumeroLotto" type="xs:string"/>
                                                                    <xs:element name="Rendita" type="bt:Valuta"/>
