                                                                        <xs:complexType>
                                                                            <xs:sequence>
                                                                                <xs:element name="DatiBene">
                                                                                    <xs:complexType>
                                                                                        <xs:sequence>
                                                                                            <xs:element name="Identificazione" type="xs:string"/>
                                                                                            <xs:element name="Descrizione" type="xs:string"/>
                                                                                            <xs:element name="Stima" type="bt:Valuta"/>
                                                                                            <xs:element name="Debitore" maxOccurs="unbounded">
