                                                                    <xs:element name="CodiceFiscale" type="bt:CodiceFiscale">
                                                                        <xs:annotation>
                                                                            <xs:documentation>dello stimatore, o professionista delegato  o custode</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="Creditore">
