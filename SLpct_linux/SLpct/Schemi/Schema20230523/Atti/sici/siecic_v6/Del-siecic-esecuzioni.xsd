                                                                <xs:documentation>Categoria credito</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="ImpComplessivo" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="ImpSoddIntegr" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="ImpNonSoddIntegr" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="PercSodd" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="TipoSpesaPrededucibile">
                                                            <xs:simpleType>
                                                                <xs:restriction base="xs:string">
                                                                    <xs:enumeration value="acconto stimatore"/>
                                                                    <xs:enumeration value="compenso e spese stimatore"/>
                                                                    <xs:enumeration value="acconto professionista delegato"/>
                                                                    <xs:enumeration value="compenso e spese professionista delegato"/>
                                                                    <xs:enumeration value="acconto custode"/>
                                                                    <xs:enumeration value="compenso e spese custode"/>
                                                                    <xs:enumeration value="acconto altro ausiliario del giudice"/>
                                                                    <xs:enumeration value="compenso e spese altro ausiliario del giudice"/>
                                                                    <xs:enumeration value="contributo di pubblicazione sul portale delle vendite"/>
                                                                    <xs:enumeration value="pubblicità sul sito Internet"/>
                                                                    <xs:enumeration value="pubblicità sul quotidiano"/>
                                                                    <xs:enumeration value="altro tipo di pubblicità"/>
                                                                    <xs:enumeration value="altro"/>
                                                                </xs:restriction>
                                                            </xs:simpleType>
                                                        </xs:element>
                                                        <xs:element name="Incaricato">
