                                                                                            <xs:element name="Descrizione" type="xs:string"/>
                                                                                            <xs:element name="Stima" type="bt:Valuta"/>
                                                                                            <xs:element name="Debitore" maxOccurs="unbounded">
                                                                                                <xs:complexType>
                                                                                                    <xs:sequence>
                                                                                                        <xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
                                                                                                        <xs:element name="Diritto">
                                                                                                            <xs:simpleType>
                                                                                                                <xs:restriction base="xs:string">
                                                                                                                    <xs:enumeration value="Proprietà"/>
                                                                                                                    <xs:enumeration value="nuda proprietà"/>
                                                                                                                    <xs:enumeration value="usufrutto"/>
                                                                                                                    <xs:enumeration value="superficie"/>
                                                                                                                    <xs:enumeration value="servitù"/>
                                                                                                                </xs:restriction>
                                                                                                            </xs:simpleType>
                                                                                                        </xs:element>
                                                                                                        <xs:element name="Frazione" type="xs:string">
                                                                                                            <xs:annotation>
                                                                                                                <xs:documentation>Quota in centesimi</xs:documentation>
                                                                                                            </xs:annotation>
                                                                                                        </xs:element>
                                                                                                        <xs:element name="Creditori" maxOccurs="unbounded">
                                                                                                            <xs:annotation>
                                                                                                                <xs:documentation>Lista di creditori per questo bene riferito a questo debitore</xs:documentation>
                                                                                                            </xs:annotation>
                                                                                                            <xs:complexType>
                                                                                                                <xs:sequence>
                                                                                                                    <xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
                                                                                                                    <xs:element name="DataRinuncia" type="xs:date" minOccurs="0">
                                                                                                                        <xs:annotation>
                                                                                                                            <xs:documentation>Data rinuncia agli atti presente solo per i creditori rinunciatari</xs:documentation>
                                                                                                                        </xs:annotation>
                                                                                                                    </xs:element>
                                                                                                                </xs:sequence>
                                                                                                            </xs:complexType>
                                                                                                        </xs:element>
                                                                                                    </xs:sequence>
                                                                                                </xs:complexType>
                                                                                            </xs:element>
                                                                                        </xs:sequence>
                                                                                    </xs:complexType>
                                                                                </xs:element>
                                                                            </xs:sequence>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="DataOrdinanzaVendita" type="xs:date"/>
                                                                    <xs:element name="DataDecretoTrasferimento" type="xs:date" minOccurs="0">
