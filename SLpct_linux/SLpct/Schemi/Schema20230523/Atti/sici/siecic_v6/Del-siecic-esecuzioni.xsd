                                                                <xs:documentation>dato dalla somma degli importi dei crediti definiti nell’elenco dei creditori</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="Note" type="xs:string" minOccurs="0"/>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                            <xs:element name="ClassificazioneGiuridica" minOccurs="4" maxOccurs="4">
                                                <xs:complexType>
                                                    <xs:sequence>
                                                        <xs:element name="CategoriaCredito" type="CategoriaCredito">
