                                                                <xs:documentation>Categoria economica immobiliare</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="ImpComplessivo" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="ImpSoddIntegr" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="ImpNonSoddIntegr" type="bt:Valuta" minOccurs="0"/>
                                                        <xs:element name="ImpTotNonSodd" type="bt:Valuta" minOccurs="0"/>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                        </xs:sequence>
                                    </xs:complexType>
                                </xs:element>
                                <xs:element name="SchedeApprofondimento">
                                    <xs:complexType>
                                        <xs:sequence>
                                            <xs:element name="Incarico" minOccurs="0" maxOccurs="unbounded">
