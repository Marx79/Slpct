                                                                    <xs:element name="DataAggiudicazione" type="xs:date"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="Risarcimento" minOccurs="0" maxOccurs="unbounded">
                                                            <xs:annotation>
                                                                <xs:documentation>Eventuali cause accessorie”, “risarcimento danni</xs:documentation>
                                                            </xs:annotation>
                                                            <xs:complexType>
                                                                <xs:sequence>
                                                                    <xs:element name="NumeroLotto" type="xs:string"/>
                                                                    <xs:element name="Importo" type="bt:Valuta"/>
                                                                    <xs:element name="DataDecreto" type="xs:date"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="AltriImporti" minOccurs="0" maxOccurs="unbounded">
                                                            <xs:complexType>
                                                                <xs:sequence>
                                                                    <xs:element name="NumeroLotto" type="xs:string"/>
                                                                    <xs:element name="Importo" type="bt:Valuta"/>
                                                                    <xs:element name="Causale" type="xs:string"/>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="SommaConfiscata" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>conversione pignoramento</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="Note" type="xs:string" minOccurs="0"/>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                        </xs:sequence>
                                    </xs:complexType>
                                </xs:element>
                                <xs:element name="SchedeApprofondimento">
                                    <xs:complexType>
                                        <xs:sequence>
                                            <xs:element name="Incarico" minOccurs="0" maxOccurs="unbounded">
                                                <xs:complexType>
                                                    <xs:sequence>
                                                        <xs:element name="Cognome" type="xs:string"/>
                                                        <xs:element name="Nome" type="xs:string"/>
                                                        <xs:element name="CodiceFiscale" type="bt:CodiceFiscale"/>
                                                        <xs:element name="CategoriaProfessionale">
                                                            <xs:annotation>
                                                                <xs:documentation>Specificare il tipo di incarico, se lo stesso e di tipo altro descrivere nel campo note</xs:documentation>
                                                            </xs:annotation>
                                                            <xs:simpleType>
                                                                <xs:restriction base="xs:string">
                                                                    <xs:enumeration value="avvocato"/>
                                                                    <xs:enumeration value="commercialista"/>
                                                                    <xs:enumeration value="altro professionista"/>
                                                                    <xs:enumeration value="IVG"/>
                                                                </xs:restriction>
                                                            </xs:simpleType>
                                                        </xs:element>
                                                        <xs:element name="Stato">
                                                            <xs:simpleType>
                                                                <xs:restriction base="xs:string">
                                                                    <xs:enumeration value="in corso"/>
                                                                    <xs:enumeration value="definito"/>
                                                                </xs:restriction>
                                                            </xs:simpleType>
                                                        </xs:element>
                                                        <xs:element name="Tipo">
                                                            <xs:simpleType>
                                                                <xs:restriction base="xs:string">
                                                                    <xs:enumeration value="cause civili"/>
                                                                    <xs:enumeration value="consulenza"/>
                                                                    <xs:enumeration value="altro"/>
                                                                </xs:restriction>
                                                            </xs:simpleType>
                                                        </xs:element>
                                                        <xs:element name="Affari" type="xs:int">
                                                            <xs:annotation>
                                                                <xs:documentation>Nr. affari (o posizioni)</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="ValoreAffari" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>valore complessivo nominale degli affari (o posizioni)  dello stesso tipo</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="DataIncarico" type="xs:date"/>
                                                        <xs:element name="LiquiditaTotale" type="bt:Valuta"/>
                                                        <xs:element name="TotaleCompensi" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>il totale compensi liquidati, anche a titolo di acconto, va riferito all'incarico, anche se ricomprende più affari (o posizioni)</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="TotaleSpese" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>totale altre spese sostenute per tutti gli incarichi dello stesso tipo</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="Note" type="xs:string" minOccurs="0">
                                                            <xs:annotation>
                                                                <xs:documentation>note da utilizzare specialmente per dettagliare il tipo di incarico qualora questo sia stato specificato come tipo altro</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                        </xs:sequence>
                                    </xs:complexType>
                                </xs:element>
                                <xs:element name="Contabilita">
                                    <xs:complexType>
                                        <xs:sequence>
                                            <xs:element name="ContiCorrentiLibretti" minOccurs="0" maxOccurs="unbounded">
                                                <xs:complexType>
                                                    <xs:sequence>
                                                        <xs:element name="TipoCCLibretto">
                                                            <xs:simpleType>
                                                                <xs:restriction base="xs:string">
                                                                    <xs:enumeration value="ContoCorrente"/>
                                                                    <xs:enumeration value="libretto"/>
                                                                </xs:restriction>
                                                            </xs:simpleType>
                                                        </xs:element>
                                                        <xs:element name="Numero" type="xs:string"/>
                                                        <xs:element name="NomeIstituto" type="xs:string"/>
                                                        <xs:element name="Agenzia" type="xs:string"/>
                                                        <xs:element name="Intestazione" type="xs:string"/>
                                                        <xs:element name="DataApertura" type="xs:date"/>
                                                        <xs:element name="UltimoSaldo" type="bt:Valuta"/>
                                                        <xs:element name="DataSaldo" type="xs:date"/>
                                                        <xs:element name="Costi" type="bt:Valuta"/>
                                                        <xs:element name="TotaleSaldo" type="bt:Valuta"/>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                            <xs:element name="EntrateUscite">
                                                <xs:complexType>
                                                    <xs:sequence>
                                                        <xs:element name="Entrate">
                                                            <xs:complexType>
                                                                <xs:sequence>
                                                                    <xs:element name="LiquidazioneBeniMobili" type="bt:Valuta"/>
                                                                    <xs:element name="Altro" type="bt:Valuta"/>
                                                                    <xs:element name="TotaleAttivo" type="bt:Valuta" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Non è obbligatorio l'inserimento in quanto corrisponde al totale di tutte le voci di entrate inserite.</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="Uscite">
                                                            <xs:complexType>
                                                                <xs:sequence>
                                                                    <xs:element name="AccontoCompensoEspertoEstimatore">
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="bt:Valuta">
                                                                                    <xs:attribute name="DiCuiAnticipate" type="bt:Valuta"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="AccontoCompensoCustodeGiudiziario">
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="bt:Valuta">
                                                                                    <xs:attribute name="DiCuiAnticipate" type="bt:Valuta"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="AccontoCompensoDelegato">
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="bt:Valuta">
                                                                                    <xs:attribute name="DiCuiAnticipate" type="bt:Valuta"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="AccontoCompensoAltri">
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="bt:Valuta">
                                                                                    <xs:attribute name="DiCuiAnticipate" type="bt:Valuta"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="SpesePubblicita">
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="bt:Valuta">
                                                                                    <xs:attribute name="DiCuiAnticipate" type="bt:Valuta"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="AltreSpese">
                                                                        <xs:annotation>
                                                                            <xs:documentation>spese per la cancellazione delle formalita' pregiudizievoli dove poste a carico della procedura</xs:documentation>
                                                                        </xs:annotation>
                                                                        <xs:complexType>
                                                                            <xs:simpleContent>
                                                                                <xs:extension base="bt:Valuta">
                                                                                    <xs:attribute name="DiCuiAnticipate" type="bt:Valuta"/>
                                                                                </xs:extension>
                                                                            </xs:simpleContent>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="TotaleSpese" type="bt:Valuta" minOccurs="0">
                                                                        <xs:annotation>
                                                                            <xs:documentation>Non è obbligatorio l'inserimento in quanto corrisponde al totale di tutte le voci di uscite inserite.</xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:element>
                                                                </xs:sequence>
                                                            </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="Saldo" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>dato da Attivo – Uscite</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="SaldoRipartito" type="bt:Valuta">
                                                            <xs:annotation>
                                                                <xs:documentation>dato da Attivo – Uscite + Totale uscite di cui anticipate</xs:documentation>
                                                            </xs:annotation>
                                                        </xs:element>
                                                        <xs:element name="Note" type="xs:string" minOccurs="0"/>
                                                    </xs:sequence>
                                                </xs:complexType>
                                            </xs:element>
                                        </xs:sequence>
                                    </xs:complexType>
                                </xs:element>
                                <xs:element name="NoteGenerali" type="xs:string" minOccurs="0"/>
                            </xs:sequence>
                        </xs:complexType>
                        <xs:key name="PK_DEB_MOB">
                            <xs:selector xpath="Parti/Debitori"/>
                            <xs:field xpath="CodiceFiscale"/>
                        </xs:key>
                        <xs:keyref name="PK_DEB_CRED_MOB" refer="PK_DEB_MOB">
                            <xs:selector xpath="Parti/Creditori/Debitori"/>
                            <xs:field xpath="CodiceFiscale"/>
                        </xs:keyref>
                        <xs:key name="PK_CRED_MOB">
