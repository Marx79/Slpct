                                                                                                        </xs:element>
                                                                                                        <xs:element name="Frazione" type="xs:string">
                                                                                                            <xs:annotation>
                                                                                                                <xs:documentation>Quota in centesimi</xs:documentation>
                                                                                                            </xs:annotation>
                                                                                                        </xs:element>
                                                                                                    </xs:sequence>
                                                                                                </xs:complexType>
                                                                                            </xs:element>
                                                                                        </xs:sequence>
                                                                                    </xs:complexType>
                                                                                </xs:element>
                                                                            </xs:sequence>
                                                                        </xs:complexType>
                                                                    </xs:element>
                                                                    <xs:element name="DataOrdinanzaVendita" type="xs:date"/>
                                                                    <xs:element name="TentativiVendita" minOccurs="0" maxOccurs="unbounded">
                                                                        <xs:complexType>
                                                                            <xs:sequence>
